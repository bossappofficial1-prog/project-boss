# Staging Environment Variables
# Copy this file to .env.staging and fill in the values

# Database Configuration
DB_DATABASE=project_boss_staging
DB_USER=staging_user
DB_PASSWORD=your_staging_db_password

# Docker Configuration
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password

# Server Configuration
STAGING_VPS_HOST=your.staging.server.com
STAGING_VPS_USER=ubuntu
STAGING_DEPLOY_PATH=/opt/project-boss-staging
STAGING_SSH_PORT=22

# Application Configuration
NODE_ENV=staging
BASE_URL=https://staging.yourdomain.com

# JWT & Security
JWT_SECRET=your_staging_jwt_secret_here
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Google OAuth (Staging)
GOOGLE_CLIENT_ID=your_staging_google_client_id
GOOGLE_CLIENT_SECRET=your_staging_google_client_secret

# Midtrans Payment (Staging)
MIDTRANS_MERCHANT_ID=your_staging_midtrans_merchant_id
MIDTRANS_SERVER_KEY=your_staging_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_staging_midtrans_client_key
MIDTRANS_NOTIFICATION_CALLBACK_URL=https://staging.yourdomain.com/api/v1/payments/notification
MIDTRANS_EXPIRE_UNIT=minutes
MIDTRANS_EXPIRE_DURATION=1440

# Email Configuration (Staging)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_staging_email@gmail.com
SMTP_PASS=your_staging_app_password

# Frontend Configuration
NUXT_PUBLIC_API_BASE=https://staging.yourdomain.com/api/v1
NUXT_HOST=0.0.0.0
NUXT_PORT=3000

# Redis (if using)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=debug
