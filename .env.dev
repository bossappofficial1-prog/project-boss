# Development Environment Configuration
# Database Configuration
DB_DATABASE=project_boss_dev
DB_USER=dev_user
DB_PASSWORD=dev_password

# Docker Configuration
DOCKER_USERNAME=your_dockerhub_username
DOCKER_PASSWORD=your_dockerhub_password

# Domain Configuration
BACKEND_DOMAIN=api-dev.bossapp.id
FRONTEND_DOMAIN=dashboard-dev.bossapp.id
FRONTEND_CUSTOMER_DOMAIN=dev.bossapp.id

# Application Configuration
NODE_ENV=development
BASE_URL=https://dev.bossapp.id
JWT_SECRET=dev_jwt_secret_change_this
BACKEND_API_URL=http://localhost:4444

# SSL/TLS Configuration (for development, you might use self-signed certificates)
SSL_CERT_PATH=/etc/ssl/certs/dev.bossapp.id.crt
SSL_KEY_PATH=/etc/ssl/private/dev.bossapp.id.key

# Email Configuration (use test settings for development)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=test_user
SMTP_PASS=test_password
SMTP_FROM=noreply@bossapp.id

# Twilio Configuration (use test credentials for development)
TWILIO_ACCOUNT_SID=test_account_sid
TWILIO_AUTH_TOKEN=test_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Midtrans Configuration
MIDTRANS_SERVER_KEY=SB-Mid-server-key
MIDTRANS_CLIENT_KEY=SB-Mid-client-key
MIDTRANS_IS_PRODUCTION=false

# Service Configuration
SERVICE_NAME=BOSS App

# Redis Configuration (if needed)
REDIS_URL=redis://localhost:6379

# RabbitMQ Configuration (if needed)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Monitoring & Logging
LOG_LEVEL=debug
ENABLE_METRICS=false

# Security (more permissive for development)
CORS_ORIGINS=https://dev.bossapp.id,https://dashboard-dev.bossapp.id,https://api-dev.bossapp.id,http://localhost:3000,http://localhost:3001,http://localhost:4444

# Development specific settings
DEBUG=true
ENABLE_SWAGGER=true
ENABLE_HOT_RELOAD=true

# Add other development-specific environment variables as needed
