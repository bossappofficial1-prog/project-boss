<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <title>Laporan Penjualan Harian - {{businessName}}</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Fira+Code:wght@400;500;600;700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', -apple-system, sans-serif;
            background: #ffffff;
            color: #0f172a;
            font-size: 11px;
            line-height: 1.6;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        @media print {
            @page {
                size: A4 portrait;
                margin: 14mm 13mm;
            }
        }

        .page {
            width: 100%;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 18px;
            padding-bottom: 16px;
            border-bottom: 1.5px solid #e2e8f0;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-box {
            width: 44px;
            height: 44px;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
        }

        .logo-text {
            color: #ef4444;
            font-size: 14px;
            font-weight: 800;
            letter-spacing: 0.5px;
        }

        .logo-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            border-radius: 10px;
        }

        .header-brand h1 {
            font-size: 17px;
            font-weight: 700;
            color: #0f172a;
            letter-spacing: -0.3px;
            line-height: 1.2;
        }

        .header-brand p {
            font-size: 9.5px;
            color: #64748b;
            margin-top: 3px;
        }

        .header-right {
            text-align: right;
        }

        .doc-type {
            display: inline-block;
            background: #fff1f2;
            border: 1px solid #fecdd3;
            border-radius: 4px;
            padding: 3px 9px;
            font-size: 7.5px;
            font-weight: 700;
            color: #ef4444;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 5px;
        }

        .doc-number {
            font-family: 'Fira Code', monospace;
            font-size: 10.5px;
            font-weight: 600;
            color: #0f172a;
            display: block;
            margin-bottom: 2px;
        }

        .doc-meta {
            font-size: 8.5px;
            color: #94a3b8;
        }

        .meta-bar {
            display: flex;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 20px;
            background: #f8fafc;
        }

        .meta-bar-item {
            flex: 1;
            padding: 9px 14px;
            border-right: 1px solid #e2e8f0;
        }

        .meta-bar-item:last-child {
            border-right: none;
        }

        .meta-bar-label {
            font-size: 7.5px;
            font-weight: 600;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 2px;
        }

        .meta-bar-value {
            font-size: 10px;
            font-weight: 600;
            color: #334155;
        }

        .section-title {
            font-size: 8.5px;
            font-weight: 700;
            color: #0f172a;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .section-title::before {
            content: '';
            display: block;
            width: 3px;
            height: 11px;
            background: #ef4444;
            border-radius: 2px;
            flex-shrink: 0;
        }

        .kpi-grid {
            display: flex;
            gap: 10px;
            margin-bottom: 22px;
        }

        .kpi-card {
            flex: 1;
            border-radius: 10px;
            padding: 13px 14px;
            border: 1px solid;
        }

        .kpi-label {
            font-size: 7.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-bottom: 7px;
        }

        .kpi-value {
            font-family: 'Fira Code', monospace;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: -0.3px;
            line-height: 1;
            margin-bottom: 5px;
        }

        .kpi-sub {
            font-size: 8px;
        }

        .kpi-revenue {
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

        .kpi-revenue .kpi-label {
            color: #15803d;
        }

        .kpi-revenue .kpi-value {
            color: #16a34a;
        }

        .kpi-revenue .kpi-sub {
            color: #15803d;
        }

        .kpi-expense {
            background: #fef2f2;
            border-color: #fecaca;
        }

        .kpi-expense .kpi-label {
            color: #b91c1c;
        }

        .kpi-expense .kpi-value {
            color: #dc2626;
        }

        .kpi-expense .kpi-sub {
            color: #b91c1c;
        }

        .kpi-profit-pos {
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

        .kpi-profit-pos .kpi-label {
            color: #15803d;
        }

        .kpi-profit-pos .kpi-value {
            color: #16a34a;
        }

        .kpi-profit-pos .kpi-sub {
            color: #15803d;
        }

        .kpi-profit-neg {
            background: #fef2f2;
            border-color: #fecaca;
        }

        .kpi-profit-neg .kpi-label {
            color: #b91c1c;
        }

        .kpi-profit-neg .kpi-value {
            color: #dc2626;
        }

        .kpi-profit-neg .kpi-sub {
            color: #b91c1c;
        }

        .kpi-trx {
            background: #f8fafc;
            border-color: #e2e8f0;
        }

        .kpi-trx .kpi-label {
            color: #475569;
        }

        .kpi-trx .kpi-value {
            color: #0f172a;
        }

        .kpi-trx .kpi-sub {
            color: #64748b;
        }

        .table-wrap {
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 22px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        thead tr {
            background: #0f172a;
        }

        th {
            color: #ffffff;
            font-size: 7.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            padding: 9px 12px;
        }

        td {
            padding: 10px 12px;
            color: #334155;
            font-size: 10px;
            border-bottom: 1px solid #f1f5f9;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:nth-child(even) td {
            background: #fafafa;
        }

        tr {
            page-break-inside: avoid;
        }

        .tr-total td {
            background: #f1f5f9 !important;
            border-top: 1.5px solid #cbd5e1;
            font-weight: 700;
            color: #0f172a;
        }

        .tc {
            text-align: center;
        }

        .tr {
            text-align: right;
        }

        .fw6 {
            font-weight: 600;
            color: #0f172a;
        }

        .mono {
            font-family: 'Fira Code', monospace;
        }

        .muted {
            color: #94a3b8;
            font-size: 8.5px;
            margin-top: 1px;
        }

        .val-pos {
            color: #16a34a;
            font-weight: 600;
            font-family: 'Fira Code', monospace;
        }

        .val-neg {
            color: #dc2626;
            font-weight: 600;
            font-family: 'Fira Code', monospace;
        }

        .val-profit-pos {
            color: #16a34a;
            font-weight: 700;
            font-family: 'Fira Code', monospace;
        }

        .val-profit-neg {
            color: #dc2626;
            font-weight: 700;
            font-family: 'Fira Code', monospace;
        }

        .row-num {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 18px;
            height: 18px;
            background: #f1f5f9;
            border-radius: 4px;
            font-family: 'Fira Code', monospace;
            font-size: 8.5px;
            font-weight: 600;
            color: #94a3b8;
        }

        .margin-pos {
            color: #16a34a;
            font-weight: 700;
            font-family: 'Fira Code', monospace;
        }

        .margin-neg {
            color: #dc2626;
            font-weight: 700;
            font-family: 'Fira Code', monospace;
        }

        .footer {
            margin-top: 28px;
            padding-top: 14px;
            border-top: 1.5px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            page-break-inside: avoid;
        }

        .footer-note {
            font-size: 8px;
            color: #94a3b8;
            max-width: 360px;
            line-height: 1.6;
        }

        .footer-note strong {
            color: #64748b;
        }

        .signature-box {
            text-align: center;
            width: 160px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 12px 14px;
        }

        .sig-title {
            font-size: 7.5px;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 20px;
        }

        .sig-name {
            font-weight: 700;
            color: #0f172a;
            font-size: 10px;
            border-top: 1px dashed #cbd5e1;
            padding-top: 6px;
            letter-spacing: 0.2px;
        }

        .sig-sub {
            font-size: 7.5px;
            color: #94a3b8;
            margin-top: 2px;
        }
    </style>
</head>

<body>
    <div class="page">

        <div class="header">
            <div class="header-left">
                <div class="logo-box">
                    {{#if logoBase64}}
                    <img class="logo-img" src="{{logoBase64}}" alt="Logo">
                    {{else}}
                    <div class="logo-text">BOSS</div>
                    {{/if}}
                </div>
                <div class="header-brand">
                    <h1>Laporan Penjualan Harian</h1>
                    <p>{{businessName}} &bull; Pemilik: {{ownerName}}</p>
                </div>
            </div>
            <div class="header-right">
                <div class="doc-type">Dokumen Resmi</div>
                <span class="doc-number">{{docNumber}}</span>
                <div class="doc-meta">Dicetak: {{generatedAt}}</div>
            </div>
        </div>

        <div class="meta-bar">
            <div class="meta-bar-item">
                <div class="meta-bar-label">Tanggal Laporan</div>
                <div class="meta-bar-value">{{date}}</div>
            </div>
            <div class="meta-bar-item">
                <div class="meta-bar-label">Periode</div>
                <div class="meta-bar-value">Harian</div>
            </div>
            <div class="meta-bar-item">
                <div class="meta-bar-label">Metode Pengiriman</div>
                <div class="meta-bar-value">Email Otomatis</div>
            </div>
            <div class="meta-bar-item">
                <div class="meta-bar-label">Jumlah Outlet</div>
                <div class="meta-bar-value">{{outletCount}} Outlet</div>
            </div>
        </div>

        <div class="section-title">Ringkasan Finansial Bisnis</div>
        <div class="kpi-grid">
            <div class="kpi-card kpi-revenue">
                <div class="kpi-label">Total Pendapatan</div>
                <div class="kpi-value">{{formatRupiah totalRevenue}}</div>
                <div class="kpi-sub">Rata-rata {{formatRupiah avgRevenuePerTrx}} / trx</div>
            </div>
            <div class="kpi-card kpi-expense">
                <div class="kpi-label">Total Pengeluaran</div>
                <div class="kpi-value">{{formatRupiah totalExpense}}</div>
                <div class="kpi-sub">{{expenseRatio}}% dari pendapatan</div>
            </div>
            <div class="kpi-card {{#if isNetProfitPositive}}kpi-profit-pos{{else}}kpi-profit-neg{{/if}}">
                <div class="kpi-label">Laba Bersih</div>
                <div class="kpi-value">{{formatRupiah netProfit}}</div>
                <div class="kpi-sub">Margin {{profitMargin}}% &bull; {{#if
                    isNetProfitPositive}}Surplus{{else}}Defisit{{/if}}</div>
            </div>
            <div class="kpi-card kpi-trx">
                <div class="kpi-label">Total Transaksi</div>
                <div class="kpi-value">{{totalTransactions}}</div>
                <div class="kpi-sub">Transaksi selesai hari ini</div>
            </div>
        </div>

        <div class="section-title">Rincian Performa Per Outlet</div>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th class="tc" style="width:36px;">No</th>
                        <th>Nama Outlet</th>
                        <th class="tc" style="width:80px;">Transaksi</th>
                        <th class="tr" style="width:115px;">Pendapatan</th>
                        <th class="tr" style="width:115px;">Pengeluaran</th>
                        <th class="tr" style="width:115px;">Laba Bersih</th>
                        <th class="tc" style="width:60px;">Margin</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each outlets}}
                    <tr>
                        <td class="tc"><span class="row-num">{{rowNumber @index}}</span></td>
                        <td class="fw6">
                            {{name}}
                            {{#if outletType}}<div class="muted">{{outletType}}</div>{{/if}}
                        </td>
                        <td class="tc mono">{{transactionCount}} Trx</td>
                        <td class="tr val-pos">{{formatRupiah revenue}}</td>
                        <td class="tr val-neg">{{formatRupiah expense}}</td>
                        <td class="tr {{#if isNetProfitPositive}}val-profit-pos{{else}}val-profit-neg{{/if}}">
                            {{formatRupiah netProfit}}</td>
                        <td class="tc {{#if isNetProfitPositive}}margin-pos{{else}}margin-neg{{/if}}">{{profitMargin}}%
                        </td>
                    </tr>
                    {{/each}}
                    <tr class="tr-total">
                        <td class="tc" colspan="2">TOTAL KESELURUHAN</td>
                        <td class="tc mono">{{totalTransactions}} Trx</td>
                        <td class="tr val-pos">{{formatRupiah totalRevenue}}</td>
                        <td class="tr val-neg">{{formatRupiah totalExpense}}</td>
                        <td class="tr {{#if isNetProfitPositive}}val-profit-pos{{else}}val-profit-neg{{/if}}">
                            {{formatRupiah netProfit}}</td>
                        <td class="tc {{#if isNetProfitPositive}}margin-pos{{else}}margin-neg{{/if}}">{{profitMargin}}%
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="footer">
            <div class="footer-note">
                <strong>Catatan:</strong> Laporan ini dibuat otomatis oleh BOSS untuk periode {{date}}.
                Seluruh angka bersumber dari transaksi kasir yang telah diselesaikan.
                Harap simpan dokumen ini sebagai arsip keuangan harian bisnis Anda.
            </div>
            <div class="signature-box">
                <div class="sig-title">Laporan Resmi</div>
                <div class="sig-name">{{businessName}}</div>
                <div class="sig-sub">{{date}}</div>
            </div>
        </div>

    </div>
</body>

</html>