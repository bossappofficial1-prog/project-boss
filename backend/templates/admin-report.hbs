<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <title>{{title}}</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Fira+Code:wght@400;500;600;700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', -apple-system, sans-serif;
            background: #ffffff;
            color: #0f172a;
            font-size: 11px;
            line-height: 1.6;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        @media print {
            @page {
                size: A4 portrait;
                margin: 14mm 13mm;
            }
        }

        .page {
            width: 100%;
        }

        /* === HEADER === */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 18px;
            padding-bottom: 16px;
            border-bottom: 1.5px solid #e2e8f0;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-box {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .logo-text {
            color: #ef4444;
            font-size: 14px;
            font-weight: 800;
            letter-spacing: 0.5px;
        }

        .logo-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            border-radius: 10px;
        }

        .header-brand h1 {
            font-size: 17px;
            font-weight: 700;
            color: #0f172a;
            letter-spacing: -0.3px;
            line-height: 1.2;
        }

        .header-brand p {
            font-size: 9.5px;
            color: #64748b;
            margin-top: 3px;
        }

        .header-right {
            text-align: right;
        }

        .doc-type {
            display: inline-block;
            background: #fff1f2;
            border: 1px solid #fecdd3;
            border-radius: 4px;
            padding: 3px 9px;
            font-size: 7.5px;
            font-weight: 700;
            color: #ef4444;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 5px;
        }

        .doc-number {
            font-family: 'Fira Code', monospace;
            font-size: 10.5px;
            font-weight: 600;
            color: #0f172a;
            display: block;
            margin-bottom: 2px;
        }

        .doc-meta {
            font-size: 8.5px;
            color: #94a3b8;
        }

        /* === META BAR === */
        .meta-bar {
            display: flex;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 20px;
            background: #f8fafc;
        }

        .meta-bar-item {
            flex: 1;
            padding: 9px 14px;
            border-right: 1px solid #e2e8f0;
        }

        .meta-bar-item:last-child {
            border-right: none;
        }

        .meta-bar-label {
            font-size: 7.5px;
            font-weight: 600;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 2px;
        }

        .meta-bar-value {
            font-size: 10px;
            font-weight: 600;
            color: #334155;
        }

        /* === SECTION TITLE === */
        .section-title {
            font-size: 8.5px;
            font-weight: 700;
            color: #0f172a;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .section-title::before {
            content: '';
            display: block;
            width: 3px;
            height: 11px;
            background: #ef4444;
            border-radius: 2px;
            flex-shrink: 0;
        }

        /* === KPI GRID === */
        .kpi-grid {
            display: flex;
            gap: 10px;
            margin-bottom: 22px;
        }

        .kpi-card {
            flex: 1;
            border-radius: 10px;
            padding: 13px 14px;
            border: 1px solid;
        }

        .kpi-label {
            font-size: 7.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-bottom: 7px;
        }

        .kpi-value {
            font-family: 'Fira Code', monospace;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: -0.3px;
            line-height: 1;
            margin-bottom: 5px;
        }

        .kpi-sub {
            font-size: 8px;
        }

        .kpi-revenue {
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

        .kpi-revenue .kpi-label {
            color: #15803d;
        }

        .kpi-revenue .kpi-value {
            color: #16a34a;
        }

        .kpi-revenue .kpi-sub {
            color: #15803d;
        }

        .kpi-expense {
            background: #fef2f2;
            border-color: #fecaca;
        }

        .kpi-expense .kpi-label {
            color: #b91c1c;
        }

        .kpi-expense .kpi-value {
            color: #dc2626;
        }

        .kpi-expense .kpi-sub {
            color: #b91c1c;
        }

        .kpi-trx {
            background: #f8fafc;
            border-color: #e2e8f0;
        }

        .kpi-trx .kpi-label {
            color: #475569;
        }

        .kpi-trx .kpi-value {
            color: #0f172a;
        }

        .kpi-trx .kpi-sub {
            color: #64748b;
        }

        .kpi-blue {
            background: #eff6ff;
            border-color: #bfdbfe;
        }

        .kpi-blue .kpi-label {
            color: #1d4ed8;
        }

        .kpi-blue .kpi-value {
            color: #2563eb;
        }

        .kpi-blue .kpi-sub {
            color: #1d4ed8;
        }

        .kpi-amber {
            background: #fffbeb;
            border-color: #fde68a;
        }

        .kpi-amber .kpi-label {
            color: #b45309;
        }

        .kpi-amber .kpi-value {
            color: #d97706;
        }

        .kpi-amber .kpi-sub {
            color: #b45309;
        }

        /* === TABLE === */
        .table-wrap {
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 22px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        thead tr {
            background: #0f172a;
        }

        th {
            color: #ffffff;
            font-size: 7.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            padding: 9px 12px;
        }

        td {
            padding: 10px 12px;
            color: #334155;
            font-size: 10px;
            border-bottom: 1px solid #f1f5f9;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:nth-child(even) td {
            background: #fafafa;
        }

        tr {
            page-break-inside: avoid;
        }

        .tr-total td {
            background: #f1f5f9 !important;
            border-top: 1.5px solid #cbd5e1;
            font-weight: 700;
            color: #0f172a;
        }

        .text-right {
            text-align: right;
        }

        .text-center {
            text-align: center;
        }

        .font-mono {
            font-family: 'Fira Code', monospace;
            font-size: 10px;
        }

        .text-success {
            color: #16a34a;
        }

        .text-danger {
            color: #dc2626;
        }

        /* === BADGE === */
        .badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 8px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .badge-active {
            background: #dcfce7;
            color: #15803d;
            border: 1px solid #bbf7d0;
        }

        .badge-trial {
            background: #dbeafe;
            color: #1d4ed8;
            border: 1px solid #bfdbfe;
        }

        .badge-expired {
            background: #fee2e2;
            color: #b91c1c;
            border: 1px solid #fecaca;
        }

        .badge-suspended {
            background: #fef3c7;
            color: #b45309;
            border: 1px solid #fde68a;
        }

        .badge-cancelled {
            background: #f1f5f9;
            color: #475569;
            border: 1px solid #e2e8f0;
        }

        /* === SUMMARY BOX === */
        .summary-box {
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 16px;
            margin-bottom: 22px;
            background: #f8fafc;
        }

        .summary-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 6px 24px;
        }

        .summary-item {
            display: flex;
            justify-content: space-between;
            padding: 5px 0;
            border-bottom: 1px dashed #e2e8f0;
        }

        .summary-item:last-child {
            border-bottom: none;
        }

        .summary-label {
            color: #64748b;
            font-size: 10px;
        }

        .summary-value {
            font-weight: 600;
            color: #0f172a;
            font-size: 10px;
            font-family: 'Fira Code', monospace;
        }

        /* === FOOTER === */
        .footer {
            margin-top: 30px;
            padding-top: 16px;
            border-top: 1.5px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .footer-left {
            font-size: 8px;
            color: #94a3b8;
            line-height: 1.8;
        }

        .footer-right {
            text-align: right;
        }

        .footer-signature {
            width: 120px;
            border-bottom: 1px solid #0f172a;
            margin-bottom: 4px;
            height: 40px;
        }

        .footer-name {
            font-size: 9px;
            font-weight: 600;
            color: #0f172a;
        }

        .footer-title {
            font-size: 8px;
            color: #64748b;
        }

        .footer-stamp {
            font-size: 7px;
            color: #94a3b8;
            margin-top: 8px;
        }
    </style>
</head>

<body>
    <div class="page">
        <!-- HEADER -->
        <div class="header">
            <div class="header-left">
                <div class="logo-box">
                    {{#if logoBase64}}
                    <img src="{{logoBase64}}" class="logo-img" alt="BOSS">
                    {{else}}
                    <span class="logo-text">B</span>
                    {{/if}}
                </div>
                <div class="header-brand">
                    <h1>BOSS Platform</h1>
                    <p>Business One Stop System</p>
                </div>
            </div>
            <div class="header-right">
                <div class="doc-type">Laporan Resmi</div>
                <div class="doc-number">{{reportNumber}}</div>
                <div class="doc-meta">{{generatedAt}}</div>
            </div>
        </div>

        <!-- META BAR -->
        <div class="meta-bar">
            <div class="meta-bar-item">
                <div class="meta-bar-label">Jenis Laporan</div>
                <div class="meta-bar-value">{{reportType}}</div>
            </div>
            <div class="meta-bar-item">
                <div class="meta-bar-label">Periode</div>
                <div class="meta-bar-value">{{periodLabel}}</div>
            </div>
            <div class="meta-bar-item">
                <div class="meta-bar-label">Dicetak</div>
                <div class="meta-bar-value">{{generatedAt}}</div>
            </div>
        </div>

        {{#if isSubscriptionSummary}}
        <!-- SUBSCRIPTION SUMMARY -->
        <div class="section-title">Ringkasan Langganan</div>
        <div class="kpi-grid">
            <div class="kpi-card kpi-revenue">
                <div class="kpi-label">Active</div>
                <div class="kpi-value">{{data.active}}</div>
                <div class="kpi-sub">Bisnis aktif</div>
            </div>
            <div class="kpi-card kpi-blue">
                <div class="kpi-label">Trial</div>
                <div class="kpi-value">{{data.trial}}</div>
                <div class="kpi-sub">Masa uji coba</div>
            </div>
            <div class="kpi-card kpi-expense">
                <div class="kpi-label">Expired</div>
                <div class="kpi-value">{{data.expired}}</div>
                <div class="kpi-sub">Kadaluarsa</div>
            </div>
            <div class="kpi-card kpi-amber">
                <div class="kpi-label">Suspended</div>
                <div class="kpi-value">{{data.suspended}}</div>
                <div class="kpi-sub">Ditangguhkan</div>
            </div>
            <div class="kpi-card kpi-trx">
                <div class="kpi-label">Cancelled</div>
                <div class="kpi-value">{{data.cancelled}}</div>
                <div class="kpi-sub">Dibatalkan</div>
            </div>
        </div>

        {{#if data.planDistribution.length}}
        <div class="section-title">Distribusi Paket Langganan</div>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th style="width:40px">No</th>
                        <th>Paket</th>
                        <th class="text-center">Jumlah Bisnis</th>
                        <th class="text-center">Persentase</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each data.planDistribution}}
                    <tr>
                        <td class="text-center">{{rowNumber @index}}</td>
                        <td><span class="badge badge-active">{{this.plan}}</span></td>
                        <td class="text-center font-mono">{{this.count}}</td>
                        <td class="text-center font-mono">{{this.percentage}}%</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{/if}}
        {{/if}}

        {{#if isTransaction}}
        <!-- TRANSACTION SUMMARY -->
        <div class="section-title">Ringkasan Transaksi</div>
        <div class="kpi-grid">
            <div class="kpi-card kpi-trx">
                <div class="kpi-label">Total Transaksi</div>
                <div class="kpi-value">{{data.total}}</div>
                <div class="kpi-sub">Seluruh transaksi</div>
            </div>
            <div class="kpi-card kpi-revenue">
                <div class="kpi-label">Berhasil</div>
                <div class="kpi-value">{{data.successful}}</div>
                <div class="kpi-sub">Transaksi sukses</div>
            </div>
            <div class="kpi-card kpi-expense">
                <div class="kpi-label">Gagal</div>
                <div class="kpi-value">{{data.failed}}</div>
                <div class="kpi-sub">Transaksi gagal</div>
            </div>
            <div class="kpi-card kpi-amber">
                <div class="kpi-label">Refund</div>
                <div class="kpi-value">{{data.refunded}}</div>
                <div class="kpi-sub">Dana dikembalikan</div>
            </div>
            <div class="kpi-card kpi-revenue">
                <div class="kpi-label">Success Rate</div>
                <div class="kpi-value">{{data.successRate}}%</div>
                <div class="kpi-sub">Tingkat keberhasilan</div>
            </div>
        </div>

        <div class="section-title">Detail Metrik</div>
        <div class="summary-box">
            <div class="summary-grid">
                <div class="summary-item">
                    <span class="summary-label">Total Transaksi</span>
                    <span class="summary-value">{{data.total}}</span>
                </div>
                <div class="summary-item">
                    <span class="summary-label">Transaksi Berhasil</span>
                    <span class="summary-value text-success">{{data.successful}}</span>
                </div>
                <div class="summary-item">
                    <span class="summary-label">Transaksi Gagal</span>
                    <span class="summary-value text-danger">{{data.failed}}</span>
                </div>
                <div class="summary-item">
                    <span class="summary-label">Transaksi Refund</span>
                    <span class="summary-value">{{data.refunded}}</span>
                </div>
                <div class="summary-item">
                    <span class="summary-label">Success Rate</span>
                    <span class="summary-value text-success">{{data.successRate}}%</span>
                </div>
                <div class="summary-item">
                    <span class="summary-label">Failure Rate</span>
                    <span class="summary-value text-danger">{{data.failureRate}}%</span>
                </div>
            </div>
        </div>
        {{/if}}

        {{#if isRevenue}}
        <!-- REVENUE REPORT -->
        <div class="section-title">Ringkasan Pendapatan</div>
        <div class="kpi-grid">
            <div class="kpi-card kpi-revenue">
                <div class="kpi-label">Total Pendapatan</div>
                <div class="kpi-value">{{formatRupiah data.totalRevenue}}</div>
                <div class="kpi-sub">Pendapatan kotor</div>
            </div>
            <div class="kpi-card kpi-trx">
                <div class="kpi-label">Total Transaksi</div>
                <div class="kpi-value">{{data.totalTransactions}}</div>
                <div class="kpi-sub">Jumlah order</div>
            </div>
            <div class="kpi-card kpi-blue">
                <div class="kpi-label">Rata-rata</div>
                <div class="kpi-value">{{formatRupiah data.averagePerTransaction}}</div>
                <div class="kpi-sub">Per transaksi</div>
            </div>
        </div>

        {{#if data.dailyBreakdown.length}}
        <div class="section-title">Breakdown Harian</div>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th style="width:40px">No</th>
                        <th>Tanggal</th>
                        <th class="text-right">Pendapatan</th>
                        <th class="text-center">Jumlah Transaksi</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each data.dailyBreakdown}}
                    <tr>
                        <td class="text-center">{{rowNumber @index}}</td>
                        <td>{{this.date}}</td>
                        <td class="text-right font-mono">{{formatRupiah this.revenue}}</td>
                        <td class="text-center font-mono">{{this.count}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{/if}}
        {{/if}}

        {{#if isBusinessPerformance}}
        <!-- BUSINESS PERFORMANCE -->
        <div class="section-title">Performa Bisnis</div>
        {{#if data.businesses.length}}
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th style="width:40px">No</th>
                        <th>Nama Bisnis</th>
                        <th>Owner</th>
                        <th class="text-center">Paket</th>
                        <th class="text-right">Pendapatan</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each data.businesses}}
                    <tr>
                        <td class="text-center">{{rowNumber @index}}</td>
                        <td><strong>{{this.name}}</strong></td>
                        <td>{{this.ownerName}}</td>
                        <td class="text-center"><span class="badge badge-active">{{this.plan}}</span></td>
                        <td class="text-right font-mono">{{formatRupiah this.revenue}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{/if}}
        {{/if}}

        {{#if isUserActivity}}
        <!-- USER ACTIVITY -->
        <div class="section-title">Aktivitas Pengguna</div>
        <div class="kpi-grid">
            <div class="kpi-card kpi-trx">
                <div class="kpi-label">Total Users</div>
                <div class="kpi-value">{{data.totalUsers}}</div>
                <div class="kpi-sub">Seluruh pengguna</div>
            </div>
            <div class="kpi-card kpi-revenue">
                <div class="kpi-label">Active</div>
                <div class="kpi-value">{{data.activeUsers}}</div>
                <div class="kpi-sub">Pengguna aktif</div>
            </div>
            <div class="kpi-card kpi-amber">
                <div class="kpi-label">Suspended</div>
                <div class="kpi-value">{{data.suspendedUsers}}</div>
                <div class="kpi-sub">Ditangguhkan</div>
            </div>
            <div class="kpi-card kpi-blue">
                <div class="kpi-label">New This Month</div>
                <div class="kpi-value">{{data.newUsersThisMonth}}</div>
                <div class="kpi-sub">Bulan ini</div>
            </div>
        </div>
        {{/if}}

        <!-- FOOTER -->
        <div class="footer">
            <div class="footer-left">
                <div>Dokumen ini digenerate otomatis oleh sistem BOSS Platform</div>
                <div>Dicetak pada: {{generatedAt}}</div>
                <div>Dokumen ini sah dan tidak memerlukan tanda tangan basah</div>
            </div>
            <div class="footer-right">
                <div class="footer-signature"></div>
                <div class="footer-name">Admin BOSS</div>
                <div class="footer-title">Platform Administrator</div>
                <div class="footer-stamp">BOSS Platform &copy; {{currentYear}}</div>
            </div>
        </div>
    </div>
</body>

</html>
