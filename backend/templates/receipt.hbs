<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Struk Pembelian</title>
    <style>
        @page {
            size: 100% auto;
            margin: 0;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            width: 100%;
            margin: 0 auto;
            padding: 5mm;
            font-family: 'Consolas', 'Courier New', Courier, monospace;
            font-size: 12px;
            color: #000;
            background-color: #fff;
            line-height: 1.5;
            height: fit-content;
            min-height: unset;
        }

        .text-center {
            text-align: center;
        }

        .text-right {
            text-align: right;
        }

        .text-left {
            text-align: left;
        }

        .text-bold {
            font-weight: bold;
        }

        /* Header */
        .header {
            margin-bottom: 10px;
        }

        .header img {
            width: 52px;
            height: 52px;
            object-fit: contain;
            margin-bottom: 6px;
        }

        .store-name {
            font-size: 14px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin: 3px 0 2px;
        }

        .store-address,
        .store-phone {
            font-size: 10.5px;
            color: #333;
            line-height: 1.6;
        }

        .transaction-id {
            font-size: 9.5px;
            letter-spacing: 0.5px;
            margin-top: 6px;
            padding: 3px 8px;
            border: 1px solid #000;
            display: inline-block;
        }

        /* Dividers */
        .divider-dashed {
            border: none;
            border-top: 1px dashed #888;
            margin: 8px 0;
        }

        .divider-solid {
            border: none;
            border-top: 2px solid #000;
            margin: 8px 0;
        }

        /* Meta Info */
        .meta-info {
            display: flex;
            justify-content: space-between;
            font-size: 10.5px;
            margin-bottom: 8px;
            gap: 6px;
        }

        .meta-col {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .highlight-box {
            display: inline-block;
            padding: 2px 5px;
            background-color: #000;
            color: #fff;
            font-size: 9.5px;
            margin-top: 2px;
        }

        /* Items */
        .item-list {
            margin: 8px 0;
        }

        .item-row {
            margin-bottom: 8px;
            page-break-inside: avoid;
        }

        .item-name {
            font-weight: bold;
            font-size: 12px;
            margin-bottom: 2px;
        }

        .item-calc {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            color: #222;
            padding-left: 12px;
        }

        /* Totals */
        .total-section {
            margin-top: 8px;
            page-break-inside: avoid;
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            margin: 3px 0;
            font-size: 11.5px;
        }

        .total-row.discount {
            color: #444;
        }

        .total-row.grand-total {
            font-weight: bold;
            font-size: 15px;
            margin-top: 8px;
            padding-top: 8px;
            border-top: 2px solid #000;
        }

        /* Footer */
        .footer {
            margin-top: 16px;
            font-size: 11px;
        }

        .footer-thanks {
            font-weight: bold;
            font-size: 12px;
            margin-bottom: 4px;
        }

        .footer-brand {
            font-size: 9px;
            color: #666;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-top: 4px;
        }
    </style>
</head>

<body>

    <!-- Header Toko -->
    <div class="header text-center">
        {{#if showLogo}}
        <img src="{{photoString}}" alt="Logo Toko" />
        {{/if}}
        {{#if headerText}}
        <div style="font-size: 10px; letter-spacing: 1px; text-transform: uppercase; color: #444; margin-bottom: 4px;">
            {{headerText}}</div>
        {{/if}}
        <div class="store-name">{{storeName}}</div>
        <div class="store-address">{{address}}</div>
        <div class="store-phone">Telp: {{phone}}</div>
        <div class="transaction-id">TRX: {{transactionId}}</div>
    </div>

    <div class="divider-dashed"></div>

    <!-- Informasi Transaksi -->
    <div class="meta-info">
        <div class="meta-col text-left">
            <span>{{date}} {{time}}</span>
            <span class="text-bold">Order: #{{orderNo}}</span>
        </div>
        <div class="meta-col text-right">
            {{#if showCashier}}
            <span>Kasir: {{cashier}}</span>
            {{/if}}
            {{#if showCustomer}}
            <span>Plg: {{customerName}}</span>
            {{/if}}
            {{#if shippingAddress}}
            <div><span class="highlight-box">{{shippingAddress}}</span></div>
            {{/if}}
        </div>
    </div>

    <div class="divider-solid"></div>

    <!-- Daftar Item Belanja -->
    <div class="item-list">
        {{#each items}}
        <div class="item-row">
            <div class="item-name">{{rowNumber @index}}. {{name}}</div>
            <div class="item-calc">
                <span>{{qty}} {{unit}} x {{formatRupiah price}}</span>
                <span>{{formatRupiah subtotal}}</span>
            </div>
        </div>
        {{/each}}
    </div>

    <div class="divider-solid"></div>

    <!-- Ringkasan Total -->
    <div class="total-section">
        <div class="total-row">
            <span>Total Item</span>
            <span>{{totalQty}}</span>
        </div>
        <div class="total-row">
            <span>Subtotal</span>
            <span>Rp {{formatRupiah subTotal}}</span>
        </div>

        {{#if discountAmount}}
        <div class="total-row discount">
            <span>Potongan Poin</span>
            <span>-Rp {{formatRupiah discountAmount}}</span>
        </div>
        {{/if}}

        <div class="total-row grand-total">
            <span>TOTAL</span>
            <span>Rp {{formatRupiah total}}</span>
        </div>
    </div>

    <div class="divider-dashed" style="margin-top: 15px;"></div>

    <!-- Footer -->
    <div class="footer text-center">
        {{#if showQR}}
        {{#if qrContent}}
        <div style="margin-bottom: 10px;">
            <img src="https://api.qrserver.com/v1/create-qr-code/?size=100x100&data={{qrContent}}"
                style="width: 80px; height: 80px;">
        </div>
        {{/if}}
        {{/if}}
        <div class="footer-thanks">{{#if footerText}}{{footerText}}{{else}}Terima Kasih Telah Berbelanja!{{/if}}</div>
        <div class="footer-brand">Powered by bossapp.id</div>
    </div>

</body>

</html>