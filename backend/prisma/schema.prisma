generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                  @id @default(uuid())
  email                   String                  @unique
  name                    String
  avatar                  String?
  password                String
  role                    UserRole                @default(OWNER)
  isVerified              Boolean                 @default(false)
  verificationCode        String?
  verificationCodeExpires DateTime?
  phone                   String?
  googleId                String?                 @unique
  provider                String?                 @default("local")
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  business                Business?
  receivedTransfers       OutletTransferRequest[] @relation("ReceivedTransfers")
  sentTransfers           OutletTransferRequest[] @relation("SentTransfers")
  pushSubscriptions       PushSubscription[]
  transactionsVerified    Transaction[]           @relation("TransactionVerifiedBy")

  @@index([email])
  @@index([role])
}

model PushSubscription {
  id              String         @id @default(uuid())
  endpoint        String         @unique
  p256dh          String
  auth            String
  guestCustomerId String?
  userId          String?
  staffId         String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  guestCustomer   GuestCustomer? @relation(fields: [guestCustomerId], references: [id], onDelete: Cascade)
  staff           Staff?         @relation(fields: [staffId], references: [id], onDelete: Cascade)
  user            User?          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guestCustomerId])
  @@index([userId])
  @@index([staffId])
}

model Business {
  id                    String                 @id @default(uuid())
  name                  String
  description           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  bankName              String?
  bankAccount           String?
  accountHolder         String?
  currentSubscriptionId String?                @unique
  subscriptionStatus    SubscriptionStatus     @default(ACTIVE)
  subscriptionStartDate DateTime               @default(now())
  subscriptionEndDate   DateTime?
  subscriptionPlan      String                 @default("BASIC")
  ownerId               String                 @unique
  banners               Banner[]
  currentSubscription   BusinessSubscription?  @relation("ActiveSubscription", fields: [currentSubscriptionId], references: [id])
  owner                 User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  subscriptions         BusinessSubscription[] @relation("BusinessHistory")
  outlets               Outlet[]
  subscriptionInvoices  SubscriptionInvoice[]

  @@index([ownerId])
  @@index([subscriptionStatus])
  @@index([description])
}

model SubscriptionPlan {
  id             String                 @id @default(uuid())
  name           String
  code           String                 @unique
  promo          String?
  price          Float
  durationDays   Int
  yearlyPrice    Float                  @default(0)
  yearlyDiscount Int                    @default(0)
  features       Json
  isActive       Boolean                @default(true)
  isPopular      Boolean                @default(false)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  subscriptions  BusinessSubscription[]
}

model BusinessSubscription {
  id                String                @id @default(uuid())
  status            SubscriptionStatus
  startDate         DateTime              @default(now())
  endDate           DateTime
  billingCycle      Int                   @default(30)
  pricePerCycle     Float                 @default(0)
  nextBillingDate   DateTime?
  businessId        String
  planId            String
  autoRenew         Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  activeForBusiness Business?             @relation("ActiveSubscription")
  business          Business              @relation("BusinessHistory", fields: [businessId], references: [id], onDelete: Cascade)
  plan              SubscriptionPlan      @relation(fields: [planId], references: [id])
  invoices          SubscriptionInvoice[]

  @@index([businessId])
  @@index([endDate])
  @@index([nextBillingDate])
}

model SubscriptionInvoice {
  id              String                @id @default(uuid())
  invoiceNumber   String                @unique
  amount          Float
  status          PaymentStatus
  paymentUrl      String?
  externalId      String?
  proofImage      String?
  proofUploadedAt DateTime?
  verifiedAt      DateTime?
  rejectionReason String?
  paidAt          DateTime?
  businessId      String?
  subscriptionId  String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  business        Business?             @relation(fields: [businessId], references: [id])
  subscription    BusinessSubscription? @relation(fields: [subscriptionId], references: [id])

  @@index([createdAt])
}

model Outlet {
  id                        String                     @id @default(uuid())
  name                      String
  slug                      String                     @unique
  description               String?
  address                   String?
  phone                     String?
  instagramUrl              String?
  email                     String?                    @unique
  createdAt                 DateTime                   @default(now())
  image                     String?                    @default("/defaults/default-outlet-image.webp")
  updatedAt                 DateTime                   @updatedAt
  latitude                  Float?
  longitude                 Float?
  isOpen                    Boolean                    @default(false)
  businessId                String
  manualBankName            String?
  manualBankAccount         String?
  manualAccountHolder       String?
  manualPaymentNote         String?
  manualQrImageUrl          String?
  type                      OutletType                 @default(CUSTOM)
  loyaltyConfig             LoyaltyConfig?
  pointHistories            LoyaltyPointHistory[]
  orders                    Order[]
  cashierShifts             CashierShift[]
  business                  Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  memberships               OutletMembership[]
  operatingHours            OutletOperatingHours[]
  tables                    OutletTable[]
  transferRequests          OutletTransferRequest[]
  products                  Product[]
  staff                     Staff[]
  expenses                  Expense[]
  receiptSettings           receiptSetting?
  suppliers                 Supplier[]
  transactionDeleteRequests TransactionDeleteRequest[]
  productCategories         ProductCategory[]
  attendances               Attendance[]

  @@index([businessId])
  @@index([slug])
  @@index([latitude, longitude])
  @@index([name])
  @@index([description])
}

model OutletTable {
  id        String      @id @default(uuid())
  name      String
  capacity  Int         @default(2)
  status    TableStatus @default(AVAILABLE)
  note      String?
  outletId  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  bills     Bill[]
  orders    Order[]
  outlet    Outlet      @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
}

model OutletTransferRequest {
  id         String         @id @default(uuid())
  outletId   String
  senderId   String
  receiverId String
  status     TransferStatus @default(PENDING)
  note       String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  outlet     Outlet         @relation(fields: [outletId], references: [id], onDelete: Cascade)
  receiver   User           @relation("ReceivedTransfers", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User           @relation("SentTransfers", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([outletId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model OutletOperatingHours {
  id        String   @id @default(uuid())
  dayOfWeek Int
  openTime  DateTime
  closeTime DateTime
  isOpen    Boolean  @default(true)
  outletId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  outlet    Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([outletId, dayOfWeek])
  @@index([outletId])
}

model Staff {
  id                        String                     @id @default(uuid())
  name                      String
  phone                     String?
  username                  String?                    @unique
  password                  String
  email                     String?
  pin                       String?
  role                      StaffRole                  @default(CASHIER)
  status                    StaffStatus                @default(ACTIVE)
  outletId                  String
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  ordersHandled             Order[]
  pushSubscriptions         PushSubscription[]
  cashierShifts             CashierShift[]
  outlet                    Outlet                     @relation(fields: [outletId], references: [id], onDelete: Cascade)
  ticketCodesRedeemed       TicketCode[]
  transactionDeleteRequests TransactionDeleteRequest[]
  attendances               Attendance[]
  privileges                StaffPrivilege[]

  @@index([outletId])
  @@index([username])
  @@index([role])
  @@index([name])
}

model StaffPrivilege {
  id        String             @id @default(uuid())
  staffId   String
  privilege StaffPrivilegeType
  createdAt DateTime           @default(now())
  staff     Staff              @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, privilege])
  @@index([staffId])
}

model Product {
  id            String           @id @default(uuid())
  name          String
  description   String?
  type          ProductType
  status        ServiceStatus    @default(ACTIVE)
  outletId      String
  categoryId    String?
  image         String?          @default("/defaults/default-product-image.png")
  taxPercentage Float?
  taxName       String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  orderItems    OrderItem[]
  outlet        Outlet           @relation(fields: [outletId], references: [id], onDelete: Cascade)
  category      ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  goods         ProductGoods?
  media         ProductMedia[]
  service       ProductService?
  ticket        ProductTicket?

  @@index([outletId])
  @@index([type])
  @@index([status])
  @@index([categoryId])
}

model ProductCategory {
  id        String    @id @default(uuid())
  name      String
  outletId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  outlet    Outlet    @relation(fields: [outletId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([name, outletId])
  @@index([outletId])
}

model ProductMedia {
  id           String      @id @default(uuid())
  productId    String
  url          String
  type         MediaType   @default(IMAGE)
  source       MediaSource @default(UPLOAD)
  alt          String?
  order        Int         @default(0)
  thumbnailUrl String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, order])
}

model ProductGoods {
  id           String            @id @default(uuid())
  productId    String            @unique
  currentStock Int               @default(0)
  minStock     Int?
  maxStock     Int?
  unit         String
  averageHpp   Float             @default(0)
  sellingPrice Float
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  barcode      String?           @unique
  sku          String?
  product      Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockLogs    StockLog[]
  suppliers    SupplierProduct[]

  @@index([barcode])
  @@index([productId])
  @@index([currentStock])
}

model Supplier {
  id        String            @id @default(uuid())
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  outletId  String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  outlet    Outlet            @relation(fields: [outletId], references: [id], onDelete: Cascade)
  products  SupplierProduct[]

  @@index([outletId])
  @@index([name])
}

model SupplierProduct {
  id             String       @id @default(uuid())
  supplierId     String
  productGoodsId String
  lastPrice      Float?
  lastOrderDate  DateTime?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  supplier       Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  productGoods   ProductGoods @relation(fields: [productGoodsId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productGoodsId])
  @@index([supplierId])
  @@index([productGoodsId])
}

model ProductService {
  id                 String        @id @default(uuid())
  productId          String        @unique
  durationMinutes    Int
  sellingPrice       Float
  providerName       String
  providerPhone      String?
  providerEmail      String?
  commissionType     String        @default("PERCENTAGE")
  commissionValue    Float         @default(0)
  maxParallel        Int           @default(1)
  bookingInWorkHours Boolean       @default(true)
  mondayOpen         DateTime?
  mondayClose        DateTime?
  tuesdayOpen        DateTime?
  tuesdayClose       DateTime?
  wednesdayOpen      DateTime?
  wednesdayClose     DateTime?
  thursdayOpen       DateTime?
  thursdayClose      DateTime?
  fridayOpen         DateTime?
  fridayClose        DateTime?
  saturdayOpen       DateTime?
  saturdayClose      DateTime?
  sundayOpen         DateTime?
  sundayClose        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  bookingSlots       BookingSlot[]
  product            Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([providerName])
}

enum TicketCodeFormat {
  QR_CODE
  BARCODE_128
}

model ProductTicket {
  id            String           @id @default(uuid())
  productId     String           @unique
  sellingPrice  Float
  eventDate     DateTime
  eventEndDate  DateTime?
  venue         String
  venueAddress  String?
  mapUrl        String?
  totalQuota    Int
  soldCount     Int              @default(0)
  maxPerOrder   Int              @default(5)
  saleStartDate DateTime?
  saleEndDate   DateTime?
  terms         String?
  codeFormat    TicketCodeFormat @default(QR_CODE)
  designConfig  Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  product       Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([eventDate])
  @@index([soldCount])
}

model StockLog {
  id             String            @id @default(uuid())
  type           StockMovementType
  quantity       Int
  hppPerUnit     Float?
  referenceType  String?
  referenceId    String?
  notes          String?
  productGoodsId String
  faktur         String?
  createdAt      DateTime          @default(now())
  productGoods   ProductGoods      @relation(fields: [productGoodsId], references: [id], onDelete: Cascade)

  @@index([productGoodsId])
  @@index([type])
  @@index([createdAt])
  @@index([referenceType, referenceId])
}

model BookingSlot {
  id               String            @id @default(uuid())
  date             DateTime
  startTime        DateTime
  endTime          DateTime
  status           BookingSlotStatus @default(AVAILABLE)
  productServiceId String
  orderItemId      String?           @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  order            OrderItem?        @relation(fields: [orderItemId], references: [id])
  productService   ProductService    @relation(fields: [productServiceId], references: [id], onDelete: Cascade)

  @@index([productServiceId])
  @@index([date])
  @@index([status])
}

model GuestCustomer {
  id                String                @id @default(uuid())
  name              String
  email             String?
  phone             String                @unique
  address           String?
  notes             String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @default(now()) @updatedAt
  pointHistories    LoyaltyPointHistory[]
  memberships       Membership[]
  orders            Order[]
  outletMemberships OutletMembership[]
  pushSubscriptions PushSubscription[]

  @@index([email])
  @@index([phone])
}

model CashierShift {
  id            String         @id @default(uuid())
  status        ShiftStatus    @default(OPEN)
  outletId      String
  staffId       String
  openedAt      DateTime       @default(now())
  closedAt      DateTime?
  openingCash   Float          @default(0)
  closingCash   Float?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  outlet        Outlet         @relation(fields: [outletId], references: [id], onDelete: Cascade)
  staff         Staff          @relation(fields: [staffId], references: [id], onDelete: Cascade)
  orders        Order[]
  transactions  Transaction[]
  cashMovements CashMovement[]

  @@index([outletId, status])
  @@index([staffId, status])
  @@index([openedAt])
}

model CashMovement {
  id        String           @id @default(uuid())
  type      CashMovementType
  amount    Float
  note      String?
  shiftId   String
  createdAt DateTime         @default(now())
  shift     CashierShift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([shiftId, createdAt])
  @@index([type])
}

model LoyaltyConfig {
  id               String   @id @default(uuid())
  outletId         String   @unique
  pointsEarned     Int      @default(1)
  multiplierAmount Float    @default(10000)
  minSpending      Float    @default(0)
  pointValue       Float    @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  outlet           Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
}

model OutletMembership {
  id              String        @id @default(uuid())
  guestCustomerId String
  outletId        String
  totalPoints     Int           @default(0)
  totalSpending   Float         @default(0)
  status          String        @default("ACTIVE")
  joinedAt        DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  guestCustomer   GuestCustomer @relation(fields: [guestCustomerId], references: [id], onDelete: Cascade)
  outlet          Outlet        @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([guestCustomerId, outletId])
  @@index([guestCustomerId])
  @@index([outletId])
}

model LoyaltyPointHistory {
  id              String                  @id @default(uuid())
  outletId        String
  guestCustomerId String
  orderId         String?
  type            LoyaltyPointHistoryType
  points          Int
  note            String?
  createdAt       DateTime                @default(now())
  guestCustomer   GuestCustomer           @relation(fields: [guestCustomerId], references: [id], onDelete: Cascade)
  order           Order?                  @relation(fields: [orderId], references: [id])
  outlet          Outlet                  @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId, guestCustomerId, createdAt])
  @@index([orderId])
}

model Order {
  id                       String                    @id @default(uuid())
  totalAmount              Float
  taxAmount                Float                     @default(0)
  discountAmount           Float                     @default(0)
  pointsRedeemed           Int                       @default(0)
  bookingDate              DateTime?
  bookingDurationMinutes   Int?
  customerType             CustomerType              @default(GUEST)
  paymentStatus            PaymentStatus             @default(PENDING)
  paymentReminderSent      Boolean                   @default(false)
  orderStatus              OrderStatus               @default(AWAITING_PAYMENT)
  notes                    String?
  cancellationReason       String?
  midtransTransactionToken String?                   @unique
  midtransRedirectUrl      String?
  midtransFee              Float                     @default(0)
  appFee                   Float                     @default(0)
  guestCustomerId          String
  outletId                 String
  handledByStaffId         String?
  cashierShiftId           String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  tableNumber              String?
  tableId                  String?
  billId                   String?
  pointHistories           LoyaltyPointHistory[]
  memberships              Membership[]
  bill                     Bill?                     @relation(fields: [billId], references: [id])
  guestCustomer            GuestCustomer             @relation(fields: [guestCustomerId], references: [id], onDelete: Cascade)
  handledByStaff           Staff?                    @relation(fields: [handledByStaffId], references: [id])
  cashierShift             CashierShift?             @relation(fields: [cashierShiftId], references: [id])
  outlet                   Outlet                    @relation(fields: [outletId], references: [id], onDelete: Cascade)
  table                    OutletTable?              @relation(fields: [tableId], references: [id])
  items                    OrderItem[]
  transaction              Transaction?
  deleteRequest            TransactionDeleteRequest?

  @@index([guestCustomerId])
  @@index([outletId])
  @@index([bookingDate])
  @@index([handledByStaffId])
  @@index([cashierShiftId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([tableId])
  @@index([billId])
}

model Bill {
  id        String      @id @default(uuid())
  outletId  String
  tableId   String
  status    BillStatus  @default(OPEN)
  total     Float       @default(0)
  createdAt DateTime    @default(now())
  closedAt  DateTime?
  updatedAt DateTime    @updatedAt
  table     OutletTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([tableId])
  @@index([outletId, status])
}

model Membership {
  id              String        @id @default(uuid())
  guestCustomerId String
  orderId         String
  joinedAt        DateTime      @default(now())
  point           Int           @default(0)
  guestCustomer   GuestCustomer @relation(fields: [guestCustomerId], references: [id], onDelete: Cascade)
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([guestCustomerId, orderId])
  @@index([guestCustomerId])
  @@index([orderId])
}

model OrderItem {
  id                      String       @id @default(uuid())
  quantity                Int
  priceAtTimeOfOrder      Float
  hppAtTimeOfOrder        Float        @default(0)
  commissionAtTimeOfOrder Float        @default(0)
  orderId                 String
  productId               String
  bookingSlot             BookingSlot?
  order                   Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product                 Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  ticketCodes             TicketCode[]

  @@index([orderId])
  @@index([productId])
}

model TicketCode {
  id           String           @id @default(uuid())
  code         String           @unique
  status       TicketCodeStatus @default(VALID)
  orderItemId  String
  redeemedAt   DateTime?
  redeemedById String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  orderItem    OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  redeemedBy   Staff?           @relation(fields: [redeemedById], references: [id])

  @@index([code])
  @@index([orderItemId])
  @@index([status])
}

model Transaction {
  id              String                    @id @default(uuid())
  amount          Float
  paymentMethod   String?
  status          PaymentStatus             @default(PENDING)
  isManual        Boolean                   @default(false)
  manualMethod    ManualPaymentType?
  cashReceived    Float?
  cashChange      Float?
  paymentProofUrl String?
  proofUploadedAt DateTime?
  verifiedAt      DateTime?
  verifiedById    String?
  rejectionNote   String?
  rawMidtrans     Json?
  externalId      String?                   @unique
  paymentUrl      String?
  expiresAt       DateTime?
  orderId         String                    @unique
  cashierShiftId  String?
  createdAt       DateTime                  @default(now())
  order           Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  verifiedBy      User?                     @relation("TransactionVerifiedBy", fields: [verifiedById], references: [id])
  cashierShift    CashierShift?             @relation(fields: [cashierShiftId], references: [id])
  deleteRequest   TransactionDeleteRequest?

  @@index([status])
  @@index([isManual, status])
  @@index([cashierShiftId])
}

model TransactionDeleteRequest {
  id             String              @id @default(uuid())
  transactionId  String?             @unique
  orderId        String              @unique
  outletId       String
  requestedBy    String
  reason         String?
  status         DeleteRequestStatus @default(PENDING)
  approvedBy     String?
  approvedByRole String?
  approvedById   String?
  approvedAt     DateTime?
  rejectionNote  String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  customerName   String
  customerPhone  String
  items          Json
  totalAmount    Float
  transaction    Transaction?        @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  order          Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  outlet         Outlet              @relation(fields: [outletId], references: [id], onDelete: Cascade)
  requestedStaff Staff?              @relation(fields: [requestedBy], references: [id], onDelete: SetNull)

  @@index([outletId])
  @@index([status])
  @@index([createdAt])
  @@index([transactionId])
  @@index([orderId])
}

model Expense {
  id          String   @id @default(uuid())
  cashier     String   @default("Owner")
  description String
  amount      Float
  date        DateTime
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  outletId    String
  outlet      Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
  @@index([date])
  @@map("expenses")
}

model Banner {
  id         String    @id @default(uuid())
  title      String
  subtitle   String?
  imageUrl   String
  ctaType    String    @default("url")
  ctaPayload String?
  sortOrder  Int       @default(0)
  isActive   Boolean   @default(true)
  businessId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([isActive, sortOrder])
}

model receiptSetting {
  id             String  @id @default(uuid())
  outletId       String  @unique
  printWidth     Int     @default(80)
  endFeed        Int     @default(3)
  autoCut        Boolean @default(true)
  copies         Int     @default(1)
  showLogo       Boolean @default(false)
  photoString    String?
  imageThreshold Int     @default(180)
  headerText     String?
  footerText     String?
  showCashier    Boolean @default(true)
  showCustomer   Boolean @default(true)
  showQR         Boolean @default(false)
  qrContent      String?
  outlet         Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
}

