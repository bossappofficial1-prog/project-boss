// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === ENUMS ===

enum UserRole {
  OWNER // Pemilik UMKM yang bisa login
  ADMIN // Admin platform yang memproses manual payout
}

enum ProductType {
  GOODS // Produk barang yang memiliki stok
  SERVICE // Layanan jasa
}

// Status pembayaran yang lebih sederhana untuk internal aplikasi
enum PaymentStatus {
  PENDING // Menunggu pembayaran
  PROOF_SUBMITTED // Bukti pembayaran manual telah diunggah
  AWAITING_VERIFICATION // Menunggu verifikasi admin/owner
  SUCCESS // Pembayaran berhasil
  FAILED // Pembayaran gagal
  REFUNDED // Dana dikembalikan
  EXPIRED // Waktu pembayaran habis
  CANCELLED // Pembayaran dibatalkan
  REJECTED_MANUAL // Bukti manual ditolak
}

// Status alur pesanan secara keseluruhan
enum OrderStatus {
  AWAITING_PAYMENT
  PROCESSING
  CONFIRMED
  READY
  ON_GOING
  COMPLETED
  CANCELLED
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

enum BookingSlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED // Untuk maintenance atau libur
}

enum StaffStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum ManualPaymentType {
  QRIS_OFFLINE
  OWNER_TRANSFER
  CASH
}

enum CustomerType {
  GUEST // Customer tanpa register
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
  PAST_DUE
  TRIAL
  AWAITING_PAYMENT
  PROOF_SUBMITTED
}

enum StockMovementType {
  IN // Barang masuk
  OUT // Barang keluar (via order)
  ADJUSTMENT // Koreksi stok
  RETURN // Retur
}

// Model untuk pengguna
model User {
  id                      String    @id @default(uuid())
  email                   String    @unique
  name                    String
  avatar                  String?
  password                String // Akan disimpan dalam bentuk hash
  role                    UserRole  @default(OWNER)
  isVerified              Boolean   @default(false)
  verificationCode        String?
  verificationCodeExpires DateTime?
  phone                   String? // Penting untuk notifikasi WA
  googleId                String?   @unique
  provider                String?   @default("local")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Relasi: Satu user (owner) memiliki satu bisnis
  business Business?

  // Relasi: Admin/owner yang memverifikasi transaksi manual
  transactionsVerified Transaction[] @relation("TransactionVerifiedBy")

  @@index([email])
  @@index([role])
}

model Business {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bankName      String?
  bankAccount   String?
  accountHolder String?

  currentSubscriptionId String?                @unique
  currentSubscription   BusinessSubscription?  @relation("ActiveSubscription", fields: [currentSubscriptionId], references: [id], onDelete: SetNull)
  subscriptionStatus    SubscriptionStatus     @default(ACTIVE)
  subscriptionStartDate DateTime               @default(now())
  subscriptionEndDate   DateTime?
  subscriptionPlan      String                 @default("BASIC")
  subscriptions         BusinessSubscription[] @relation("BusinessHistory")

  // Relasi: Setiap bisnis dimiliki oleh satu User (Owner)
  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Relasi: Satu bisnis bisa memiliki banyak outlet
  outlets Outlet[]

  // Relasi: Satu bisnis bisa memiliki banyak banner
  banners              Banner[]
  subscriptionInvoices SubscriptionInvoice[]

  @@index([ownerId])
  @@index([subscriptionStatus])
  @@index([description]) // Indeks untuk pencarian deskripsi bisnis
}

model SubscriptionPlan {
  id           String @id @default(uuid())
  name         String // "Basic", "Pro", "Enterprise"
  code         String @unique // "BASIC", "PRO" (untuk referensi coding)
  price        Float // Harga per bulan
  durationDays Int // 30 hari, 365 hari, atau 14 (trial)
  features     Json

  isActive  Boolean @default(true)
  isPopular Boolean @default(false)

  subscriptions BusinessSubscription[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model BusinessSubscription {
  id String @id @default(uuid())

  status SubscriptionStatus

  startDate DateTime @default(now())
  endDate   DateTime

  businessId        String
  business          Business  @relation("BusinessHistory", fields: [businessId], references: [id], onDelete: Cascade)
  activeForBusiness Business? @relation("ActiveSubscription")

  planId String
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  invoices  SubscriptionInvoice[]
  autoRenew Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([businessId])
  @@index([endDate])
}

model SubscriptionInvoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  amount        Float
  status        PaymentStatus // PENDING, PAID, FAILED, PROOF_SUBMITTED

  paymentUrl String?
  externalId String?

  proofImage      String?
  proofUploadedAt DateTime?
  verifiedAt      DateTime?
  rejectionReason String?

  paidAt DateTime?

  // Relasi
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  subscriptionId String?
  subscription   BusinessSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt]) // Penting untuk Dashboard Chart Revenue
}

// Model untuk cabang/outlet dari sebuah bisnis
model Outlet {
  id          String   @id @default(uuid())
  name        String
  description String?
  address     String?
  phone       String?
  createdAt   DateTime @default(now())
  image       String?  @default("/defaults/default-outlet-image.webp")
  updatedAt   DateTime @updatedAt
  latitude    Float?
  longitude   Float?
  isOpen      Boolean  @default(false)

  // Relasi: Setiap outlet milik satu bisnis
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Informasi pembayaran manual
  manualBankName      String?
  manualBankAccount   String?
  manualAccountHolder String?
  manualPaymentNote   String?
  manualQrImageUrl    String?

  // Relasi: Satu outlet bisa memiliki banyak produk
  products Product[]

  // Relasi: Banyak pesanan bisa dibuat di satu outlet
  orders Order[]

  // Relasi: Banyak pengeluaran bisa dicatat per outlet
  expenses Expense[]

  // Relasi untuk operating hours dan staff
  operatingHours  OutletOperatingHours[]
  staff           Staff[]
  receiptSettings receiptSetting?

  @@index([businessId])
  @@index([latitude, longitude]) // Indeks untuk query lokasi (bounding box)
  @@index([name]) // Indeks untuk pencarian nama outlet
  @@index([description]) // Indeks untuk pencarian deskripsi outlet
}

// Model untuk jam operasional outlet
model OutletOperatingHours {
  id        String   @id @default(uuid())
  dayOfWeek Int // 0-6 (Minggu-Sabtu)
  openTime  DateTime
  closeTime DateTime
  isOpen    Boolean  @default(true)

  // Relasi ke outlet
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([outletId, dayOfWeek])
  @@index([outletId])
}

// Model untuk staff/karyawan outlet (Kasir)
model Staff {
  id       String      @id @default(uuid())
  name     String
  phone    String?
  email    String?     @unique
  password String // Hash untuk login POS kasir
  status   StaffStatus @default(ACTIVE)

  // Relasi ke outlet
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  // Relasi ke pesanan yang di-handle oleh kasir
  ordersHandled Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([outletId])
  @@index([email])
}

// Model untuk produk (parent table - minimalis)
model Product {
  id          String        @id @default(uuid())
  name        String
  description String?
  type        ProductType // GOODS atau SERVICE
  status      ServiceStatus @default(ACTIVE)

  // Relasi: Setiap produk/jasa terhubung ke satu outlet
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  // Subtables (one-to-one polymorphic)
  goods   ProductGoods?
  service ProductService?
  image   String?         @default("/defaults/default-product-image.png")

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([outletId])
  @@index([type])
  @@index([status])
}

// Subtable untuk produk GOODS
model ProductGoods {
  id        String  @id @default(uuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Goods-specific fields
  currentStock Int    @default(0)
  minStock     Int? // Alert threshold untuk low stock
  unit         String // Pcs, Kg, Box, Liter, dll

  // HPP (Harga Pokok Penjualan) - calculated from stock logs
  averageHpp Float @default(0)

  // Pricing
  sellingPrice Float // Harga jual

  // Relations
  stockLogs StockLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([currentStock]) // Untuk query low stock
}

// Subtable untuk produk SERVICE
model ProductService {
  id        String  @id @default(uuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Service-specific fields
  durationMinutes Int // Durasi layanan dalam menit
  sellingPrice    Float

  // Service Provider Info (penyedia jasa)
  providerName  String
  providerPhone String?
  providerEmail String?

  // Commission/Wage untuk provider
  commissionType  String @default("PERCENTAGE") // PERCENTAGE atau FIXED
  commissionValue Float  @default(0) // % atau nominal

  // Capacity
  maxParallel Int @default(1) // Berapa banyak service bisa dilakukan bersamaan

  // Relations
  bookingSlots BookingSlot[]

  // Izinkan booking diluar jam kerja
  bookingInWorkHours Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([providerName])
}

// Log untuk tracking barang masuk/keluar (untuk HPP calculation)
model StockLog {
  id       String            @id @default(uuid())
  type     StockMovementType
  quantity Int // Positif untuk IN, bisa negatif untuk OUT

  // HPP per unit saat barang masuk (untuk tipe IN)
  hppPerUnit Float?

  // Reference ke transaksi/order yang trigger movement ini
  referenceType String? // "ORDER", "PURCHASE", "MANUAL", "ADJUSTMENT", "RETURN"
  referenceId   String? // ID dari order/purchase/etc
  notes         String?

  // Relations
  productGoodsId String
  productGoods   ProductGoods @relation(fields: [productGoodsId], references: [id], onDelete: Cascade)

  // Bukti pembelian
  faktur String?

  createdAt DateTime @default(now())

  @@index([productGoodsId])
  @@index([type])
  @@index([createdAt])
  @@index([referenceType, referenceId])
}

// Model untuk slot booking khusus layanan jasa
model BookingSlot {
  id        String            @id @default(uuid())
  date      DateTime // Tanggal booking
  startTime DateTime // Waktu mulai
  endTime   DateTime // Waktu selesai
  status    BookingSlotStatus @default(AVAILABLE)

  // Relasi: Slot ini untuk produk jasa mana
  productServiceId String
  productService   ProductService @relation(fields: [productServiceId], references: [id], onDelete: Cascade)

  // Relasi: Slot ini dibooking oleh order mana (jika sudah dibooking)
  orderItemId String?    @unique
  order       OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productServiceId])
  @@index([date])
  @@index([status])
}

// Model untuk menyimpan data customer guest (tanpa register)
model GuestCustomer {
  id    String  @id @default(uuid())
  name  String
  email String?
  phone String  @unique // Penting untuk notifikasi WA dan data booking

  // Relasi: Satu guest customer bisa punya banyak order
  orders Order[]

  createdAt DateTime @default(now())

  @@index([email])
  @@index([phone])
}

// Model untuk pesanan/booking yang dibuat oleh customer
model Order {
  id          String    @id @default(uuid())
  totalAmount Float // Menggunakan Float untuk nilai uang
  bookingDate DateTime? // Digunakan khusus untuk booking jasa

  // Tipe customer (hanya GUEST sesuai MoM)
  customerType CustomerType @default(GUEST)

  // Status pembayaran dari payment gateway
  paymentStatus PaymentStatus @default(PENDING)

  // Menandakan apakah pengingat pembayaran sudah dikirim
  paymentReminderSent Boolean @default(false)

  // Status alur pesanan secara keseluruhan
  orderStatus OrderStatus @default(AWAITING_PAYMENT)
  cancellationReason String? // jika orderStatus = CANCELLED 

  midtransTransactionToken String? @unique
  midtransRedirectUrl      String?

  // Fee structure sesuai diagram
  midtransFee Float @default(0) // 0.7% dari subtotal
  appFee      Float @default(0) // 2% dari subtotal

  // Relasi: Pesanan dibuat oleh guest customer
  guestCustomerId String
  guestCustomer   GuestCustomer @relation(fields: [guestCustomerId], references: [id], onDelete: Cascade)

  // Relasi: Pesanan dibuat di outlet mana
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  // Relasi: Pesanan bisa di-handle oleh staff tertentu (kasir)
  handledByStaffId String?
  handledByStaff   Staff?  @relation(fields: [handledByStaffId], references: [id], onDelete: SetNull)

  // Relasi: Satu pesanan punya banyak item
  items OrderItem[]

  // Relasi: Satu pesanan dibayar dengan satu transaksi
  transaction Transaction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guestCustomerId])
  @@index([outletId])
  @@index([bookingDate])
  @@index([handledByStaffId])
  @@index([orderStatus])
  @@index([paymentStatus])
}

// Item-item yang ada di dalam sebuah pesanan
model OrderItem {
  id                 String @id @default(uuid())
  quantity           Int
  priceAtTimeOfOrder Float // Menyimpan harga saat itu untuk arsip

  // Relasi: Item ini bagian dari pesanan mana
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Relasi: Item ini merujuk ke produk apa
  productId   String
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Relasi: Satu pesanan bisa book satu slot (untuk service)
  bookingSlot BookingSlot?

  @@index([orderId])
  @@index([productId])
}

// Model untuk mencatat setiap transaksi pembayaran
model Transaction {
  id            String        @id @default(uuid())
  amount        Float
  paymentMethod String? // misal: "qris", "gopay"
  status        PaymentStatus @default(PENDING)

  // Penanda pembayaran manual
  isManual        Boolean            @default(false)
  manualMethod    ManualPaymentType?
  paymentProofUrl String?
  proofUploadedAt DateTime?
  verifiedAt      DateTime?
  verifiedById    String?
  rejectionNote   String?
  rawMidtrans     Json?

  // ID transaksi dari payment gateway (misal: Midtrans transaction_id atau token)
  externalId String? @unique

  // URL untuk melakukan pembayaran (misal: Midtrans Snap redirect_url)
  paymentUrl String?

  // Waktu kedaluwarsa pembayaran dari payment gateway
  expiresAt DateTime?

  // Relasi: Transaksi ini milik pesanan mana
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Relasi ke verifikator transaksi manual
  verifiedBy User? @relation("TransactionVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([status])
  @@index([isManual, status])
}

// Model untuk mencatat pengeluaran
model Expense {
  id          String   @id @default(uuid())
  cashier     String   @default("Owner")
  description String
  amount      Float
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relasi: Pengeluaran ini terjadi di outlet mana
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
  @@index([date])
  @@map("expenses")
}

// Model for home page banners
model Banner {
  id         String  @id @default(uuid())
  title      String
  subtitle   String?
  imageUrl   String
  ctaType    String  @default("url")
  ctaPayload String?
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)

  // Optional relation to a business (banner scoped per business)
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([isActive, sortOrder])
}

model receiptSetting {
  id          String  @id @default(uuid())
  outletId    String  @unique
  photoString String?
  showLogo    Boolean @default(false)
  printHeight String  @default("105")
  printWidth  String  @default("80")
  outlet      Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
}
