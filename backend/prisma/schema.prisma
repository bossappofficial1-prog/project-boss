  @@index([productId])
}

model TicketCode {
  id           String           @id @default(uuid())
  code         String           @unique
  status       TicketCodeStatus @default(VALID)
  orderItemId  String
  redeemedAt   DateTime?
  redeemedById String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  orderItem    OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  redeemedBy   Staff?           @relation(fields: [redeemedById], references: [id])

  @@index([code])
  @@index([orderItemId])
  @@index([status])
}

model Transaction {
  id              String                    @id @default(uuid())
  amount          Float
  paymentMethod   String?
  status          PaymentStatus             @default(PENDING)
  isManual        Boolean                   @default(false)
  manualMethod    ManualPaymentType?
  cashReceived    Float?
  cashChange      Float?
  paymentProofUrl String?
  proofUploadedAt DateTime?
  verifiedAt      DateTime?
  verifiedById    String?
  rejectionNote   String?
  rawMidtrans     Json?
  externalId      String?                   @unique
  paymentUrl      String?
  expiresAt       DateTime?
  orderId         String                    @unique
  cashierShiftId  String?
  createdAt       DateTime                  @default(now())
  order           Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  verifiedBy      User?                     @relation("TransactionVerifiedBy", fields: [verifiedById], references: [id])
  cashierShift    CashierShift?             @relation(fields: [cashierShiftId], references: [id])
  deleteRequest   TransactionDeleteRequest?

  @@index([status])
  @@index([isManual, status])
  @@index([cashierShiftId])
}

model TransactionDeleteRequest {
  id             String              @id @default(uuid())
  transactionId  String?             @unique
  orderId        String              @unique
  outletId       String
  requestedBy    String
  reason         String?
  status         DeleteRequestStatus @default(PENDING)
  approvedBy     String?
  approvedByRole String?
  approvedById   String?
  approvedAt     DateTime?
  rejectionNote  String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  customerName   String
  customerPhone  String
  items          Json
  totalAmount    Float
  transaction    Transaction?        @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  order          Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  outlet         Outlet              @relation(fields: [outletId], references: [id], onDelete: Cascade)
  requestedStaff Staff?              @relation(fields: [requestedBy], references: [id], onDelete: SetNull)

  @@index([outletId])
  @@index([status])
  @@index([createdAt])
  @@index([transactionId])
  @@index([orderId])
}

model Expense {
  id          String   @id @default(uuid())
  cashier     String   @default("Owner")
  description String
  amount      Float
  date        DateTime
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
