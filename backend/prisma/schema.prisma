// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/prisma-schema

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === ENUMS ===

enum UserRole {
  OWNER // Pemilik UMKM yang bisa login
  ADMIN // Admin platform yang memproses manual payout
}

enum ProductType {
  GOODS // Produk barang yang memiliki stok
  SERVICE // Layanan jasa
}

// Status pembayaran yang lebih sederhana untuk internal aplikasi
enum PaymentStatus {
  PENDING // Menunggu pembayaran
  PROOF_SUBMITTED // Bukti pembayaran manual telah diunggah
  AWAITING_VERIFICATION // Menunggu verifikasi admin/owner
  SUCCESS // Pembayaran berhasil
  FAILED // Pembayaran gagal
  REFUNDED // Dana dikembalikan
  EXPIRED // Waktu pembayaran habis
  CANCELLED // Pembayaran dibatalkan
  REJECTED_MANUAL // Bukti manual ditolak
}

// Status alur pesanan secara keseluruhan
enum OrderStatus {
  AWAITING_PAYMENT
  PROCESSING
  CONFIRMED
  READY
  ON_GOING
  COMPLETED
  CANCELLED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

enum FeeBearer {
  CUSTOMER
  OWNER
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

enum MemberType {
  REGULAR
  VIP
  PREMIUM
}

enum BookingSlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED // Untuk maintenance atau libur
}

enum StaffStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum StaffRole {
  SERVICE // Staff yang menangani layanan/jasa
  CASHIER // Kasir
  ADMIN // Admin outlet
  INVENTORY // Staff gudang/inventory
  OTHER // Peran lainnya
}

enum ManualPaymentType {
  QRIS_OFFLINE
  OWNER_TRANSFER
  CASH
}

// === MODELS ===

// Model untuk jam operasional outlet
model OutletOperatingHours {
  id        String   @id @default(uuid())
  dayOfWeek Int // 0-6 (Minggu-Sabtu)
  openTime  DateTime
  closeTime DateTime
  isOpen    Boolean  @default(true)

  // Relasi ke outlet
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([outletId, dayOfWeek])
  @@index([outletId])
}

// Model untuk staff/karyawan outlet
model Staff {
  id     String      @id @default(uuid())
  name   String
  phone  String?
  status StaffStatus @default(ACTIVE)
  role   StaffRole   @default(OTHER)

  // Informasi tambahan
  email   String? @unique
  address String?
  notes   String?

  // Password untuk login kasir (nullable - hanya untuk kasir yang butuh login)
  password String?

  // Relasi ke outlet
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  // Relasi ke booking slots yang ditangani (khusus staff SERVICE)
  bookings BookingSlot[]

  // Relasi ke pesanan yang ditugaskan
  assignedOrders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([outletId])
}

// === MODELS ===

enum CustomerType {
  GUEST // Customer tanpa register
}

enum PromoType {
  PERCENTAGE // Diskon dalam bentuk persen, misal: 10%
  FIXED_AMOUNT // Potongan harga tetap, misal: Rp 20.000
}

enum PromoStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

// === MODELS ===

// Model untuk pengguna (hanya Owner/UMKM)
model User {
  id                      String    @id @default(uuid())
  email                   String    @unique
  name                    String
  avatar                  String?
  password                String // Akan disimpan dalam bentuk hash
  role                    UserRole  @default(OWNER)
  isVerified              Boolean   @default(false)
  verificationCode        String?
  verificationCodeExpires DateTime?
  phone                   String? // Penting untuk notifikasi WA
  googleId                String?   @unique
  provider                String?   @default("local")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Relasi: Satu user (owner) memiliki satu bisnis
  business Business?

  // Relasi: Admin/owner yang memverifikasi transaksi manual
  transactionsVerified Transaction[] @relation("TransactionVerifiedBy")

  @@index([email])
}

// Model untuk entitas bisnis utama milik seorang Owner
model Business {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Info Bank
  bankName         String?
  bankAccount      String?
  accountHolder    String?
  manualQrImageUrl String?

  // Relasi: Setiap bisnis dimiliki oleh satu User (Owner)
  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Relasi: Satu bisnis bisa memiliki banyak outlet
  outlets Outlet[]

  // Menentukan siapa yang menanggung biaya Midtrans untuk transaksi QRIS/booking
  defaultTransactionFeeBearer FeeBearer @default(OWNER)

  // Relasi: Satu bisnis bisa memiliki banyak promo
  promos Promo[]

  // Relasi: Satu bisnis bisa memiliki banyak banner
  banners Banner[]

  @@index([ownerId])
  @@index([description]) // Indeks untuk pencarian deskripsi bisnis
}

// Model untuk cabang/outlet dari sebuah bisnis
model Outlet {
  id          String   @id @default(uuid())
  name        String
  description String?
  address     String?
  phone       String?
  createdAt   DateTime @default(now())
  image       String?
  updatedAt   DateTime @updatedAt
  latitude    Float?
  longitude   Float?
  isOpen      Boolean  @default(false)
  // Relasi: Setiap outlet milik satu bisnis
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  manualQrImageUrl String?

  // Relasi: Satu outlet bisa memiliki banyak produk
  products Product[]

  // Relasi: Banyak pesanan bisa dibuat di satu outlet
  orders Order[]

  // Relasi: Banyak pengeluaran bisa dicatat per outlet
  expenses Expense[]

  // Relasi baru untuk booking features
  operatingHours OutletOperatingHours[]
  staff          Staff[]

  @@index([businessId])
  @@index([latitude, longitude]) // Indeks untuk query lokasi (bounding box)
  @@index([name]) // Indeks untuk pencarian nama outlet
  @@index([description]) // Indeks untuk pencarian deskripsi outlet
}

// Model untuk produk (barang) atau jasa yang ditawarkan
model Product {
  id          String      @id @default(uuid())
  name        String
  description String?
  costPrice   Float       @default(0) // Harga Pokok Penjualan (HPP)
  price       Float // Harga Jual
  type        ProductType // Membedakan antara BARANG atau JASA
  quantity    Int? // Jumlah stok saat ini (untuk GOODS)
  unit        String? // Satuan (misal: Pcs, Kg, Box)

  // Status layanan (untuk on/off layanan)
  status ServiceStatus @default(ACTIVE)

  // Fee cas per produk (jika null, gunakan default dari Business)
  transactionFeeBearer FeeBearer?

  // Durasi layanan dalam menit (khusus untuk SERVICE)
  serviceDurationMinutes Int?

  // Relasi: Setiap produk/jasa terhubung ke satu outlet
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  image String?

  // Relasi: Satu produk bisa ada di banyak item pesanan
  orderItems OrderItem[]

  // Relasi: Satu produk service bisa punya banyak booking slot
  bookingSlots BookingSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([outletId])
}

// Model untuk slot booking khusus layanan jasa
model BookingSlot {
  id        String            @id @default(uuid())
  date      DateTime // Tanggal booking
  startTime DateTime // Waktu mulai
  endTime   DateTime // Waktu selesai
  status    BookingSlotStatus @default(AVAILABLE)

  // Relasi: Slot ini untuk produk jasa mana
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Relasi: Slot ini dibooking oleh order mana (jika sudah dibooking)
  orderId String? @unique
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  // Relasi: Slot ini ditangani oleh staff mana
  staffId String?
  staff   Staff?  @relation(fields: [staffId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([date])
  @@index([staffId])
}

// Model untuk menyimpan data customer guest (tanpa register)
model GuestCustomer {
  id    String  @id @default(uuid())
  name  String
  email String?
  phone String? // Penting untuk notifikasi WA dan data booking

  // Relasi: Satu guest customer bisa punya banyak order
  orders Order[]

  createdAt DateTime @default(now())

  @@index([email])
  @@index([phone])
}

// Model untuk pesanan/booking yang dibuat oleh customer
model Order {
  id          String    @id @default(uuid())
  totalAmount Float // Menggunakan Float untuk nilai uang
  bookingDate DateTime? // Digunakan khusus untuk booking jasa

  // Tipe customer (hanya GUEST sesuai MoM)
  customerType CustomerType @default(GUEST)

  // Status pembayaran dari payment gateway
  paymentStatus PaymentStatus @default(PENDING)

  // Menandakan apakah pengingat pembayaran sudah dikirim
  paymentReminderSent Boolean @default(false)

  // Status alur pesanan secara keseluruhan
  orderStatus OrderStatus @default(AWAITING_PAYMENT)

  midtransTransactionToken String? @unique
  midtransRedirectUrl      String?

  // Fee structure sesuai diagram
  midtransFee Float     @default(0) // 0.7% dari subtotal
  appFee      Float     @default(0) // 2% dari subtotal
  chargedTo   FeeBearer @default(CUSTOMER)

  // Info promo yang digunakan
  promoId        String?
  promo          Promo?  @relation(fields: [promoId], references: [id], onDelete: SetNull)
  discountAmount Float   @default(0)

  // Relasi: Pesanan dibuat oleh guest customer
  guestCustomerId String
  guestCustomer   GuestCustomer @relation(fields: [guestCustomerId], references: [id], onDelete: Cascade)

  // Relasi: Pesanan dibuat di outlet mana
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  // Relasi: Pesanan bisa ditugaskan ke staff tertentu
  assignedStaffId String?
  assignedStaff   Staff?  @relation(fields: [assignedStaffId], references: [id], onDelete: SetNull)

  // Relasi: Satu pesanan punya banyak item
  items OrderItem[]

  // Relasi: Satu pesanan dibayar dengan satu transaksi
  transaction Transaction?

  // Relasi: Satu pesanan bisa book satu slot (untuk service)
  bookingSlot BookingSlot?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guestCustomerId])
  @@index([outletId])
  @@index([bookingDate])
  @@index([assignedStaffId])
}

// Item-item yang ada di dalam sebuah pesanan
model OrderItem {
  id                 String @id @default(uuid())
  quantity           Int
  priceAtTimeOfOrder Float // Menyimpan harga saat itu untuk arsip

  // Relasi: Item ini bagian dari pesanan mana
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Relasi: Item ini merujuk ke produk apa
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

// Model untuk mencatat setiap transaksi pembayaran
model Transaction {
  id            String        @id @default(uuid())
  amount        Float
  paymentMethod String? // misal: "qris", "gopay"
  status        PaymentStatus @default(PENDING)

  // Penanda pembayaran manual
  isManual        Boolean            @default(false)
  manualMethod    ManualPaymentType?
  paymentProofUrl String?
  proofUploadedAt DateTime?
  verifiedAt      DateTime?
  verifiedById    String?
  rejectionNote   String?
  rawMidtrans     Json?

  // ID transaksi dari payment gateway (misal: Midtrans transaction_id atau token)
  externalId String? @unique

  // URL untuk melakukan pembayaran (misal: Midtrans Snap redirect_url)
  paymentUrl String?

  // Waktu kedaluwarsa pembayaran dari payment gateway
  expiresAt DateTime?

  // Relasi: Transaksi ini milik pesanan mana
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Relasi ke verifikator transaksi manual
  verifiedBy User? @relation("TransactionVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([status])
  @@index([isManual, status])
}

// Model untuk mencatat pengeluaran
model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Float
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relasi: Pengeluaran ini terjadi di outlet mana
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

// Model untuk Promo/Diskon
model Promo {
  id          String      @id @default(uuid())
  code        String // Kode unik promo, misal: "HEMAT20K"
  description String?
  type        PromoType
  value       Float // Nilai diskon (bisa persen atau nominal)
  status      PromoStatus @default(ACTIVE)

  // Batasan penggunaan
  maxUses   Int? // Maksimal berapa kali promo bisa digunakan secara total
  timesUsed Int  @default(0)

  // Syarat & Ketentuan
  minPurchaseAmount Float? // Minimal pembelian untuk bisa menggunakan promo
  validFrom         DateTime @default(now())
  validUntil        DateTime

  // Relasi: Promo ini milik bisnis mana
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Relasi: Promo ini digunakan di order mana saja
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, code]) // Kode promo harus unik per bisnis
  @@index([businessId])
}

// Model for home page banners
model Banner {
  id         String  @id @default(uuid())
  title      String
  subtitle   String?
  imageUrl   String
  ctaType    String  @default("url")
  ctaPayload String?
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)

  // Optional relation to a business (banner scoped per business)
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([isActive, sortOrder])
}
