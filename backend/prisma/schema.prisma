// This is your Prisma schema file,
// learn more about it in the docs: https://pris.lyd/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// ENUMS - Untuk memastikan konsistensi data
// =============================================

enum Role {
  OWNER // Pemilik UMKM
  CUSTOMER // Pelanggan biasa
}

enum ProductType {
  GOODS // Produk barang yang memiliki stok
  SERVICE // Layanan jasa
}

enum OrderPaymentStatus {
  AUTHORIZE
  CAPTURE
  SETTLEMENT
  DENY
  PENDING
  CANCEL
  REFUND
  PARTIAL_REFUND
  CHARGEBACK
  PARTIAL_CHARGEBACK
  EXPIRE
  FAILURE
}

enum OrderQueueStatus {
  CREATED // Pesanan baru dibuat, belum diproses lebih lanjut
  AWAITING_PAYMENT // Pesanan menunggu konfirmasi pembayaran
  IN_QUEUE // Pembayaran berhasil, pesanan jasa masuk antrian
  READY_FOR_PICKUP // Pembayaran berhasil, barang fisik siap diambil
  IN_PROGRESS // Jasa sedang dikerjakan atau barang sedang disiapkan
  COMPLETED // Jasa/barang selesai diproses/diambil
  CANCELLED // Pesanan dibatalkan (misal oleh customer)
  REFUNDED // Pesanan direfund
  FAILED_PROCESSING // Gagal diproses setelah pembayaran
  UNKNOWN
}

enum TransactionStatus {
  CREATED
  PENDING
  SUCCESS
  FAILED
}

enum WithdrawalStatus {
  PENDING
  COMPLETED
  REJECTED
}

// === Enum untuk Siapa yang Menanggung Biaya ===
enum FeeBearer {
  CUSTOMER
  OWNER
}

// === Enum untuk Status Layanan ===
enum ServiceStatus {
  ACTIVE
  INACTIVE
}

// === Enum untuk Tipe Member ===
enum MemberType {
  REGULAR
  VIP
  PREMIUM
}

// === Enum untuk Status Booking Slot ===
enum BookingSlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED // Untuk maintenance atau libur
}

// === Enum untuk Tipe Customer ===
enum CustomerType {
  REGISTERED // User yang sudah register
  GUEST // Customer tanpa register
}

// Model untuk pengguna, baik Owner maupun Customer
model User {
  id                      String    @id @default(uuid())
  email                   String    @unique
  name                    String
  avatar                  String?
  password                String // Akan disimpan dalam bentuk hash
  role                    Role      @default(CUSTOMER)
  isVerified              Boolean   @default(false)
  verificationCode        String?
  verificationCodeExpires DateTime?
  phone                   String? // Tambahan untuk notifikasi WA
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Relasi: Satu user (owner) bisa memiliki banyak bisnis
  businesses Business?

  // Relasi: Satu user (customer) bisa membuat banyak pesanan
  orders Order[]

  // Relasi: Customer bisa jadi member di berbagai bisnis
  memberships Membership[]

  @@index([email])
}

// Model untuk entitas bisnis utama milik seorang Owner
model Business {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Info Bank
  bankName      String?
  bankAccount   String?
  accountHolder String?

  // Relasi: Setiap bisnis dimiliki oleh satu User (Owner)
  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Relasi: Satu bisnis bisa memiliki banyak outlet
  outlets Outlet[]

  // Relasi: Setiap bisnis memiliki satu dompet virtual
  wallet Wallet?

  // Menentukan siapa yang menanggung biaya Midtrans untuk transaksi QRIS/booking
  defaultTransactionFeeBearer FeeBearer @default(OWNER)

  // Relasi: Satu bisnis bisa memiliki banyak member
  memberships Membership[]

  @@index([ownerId])
}

// Model untuk cabang/outlet dari sebuah bisnis
model Outlet {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  image     String?  @default("https://press-parts-outlet.com/cdn/shop/files/non-photoproductimage_9c33376d-caaf-4116-b20a-3162aedf74f4_512x512.png?v=1687762014")
  updatedAt DateTime @updatedAt

  // Relasi: Setiap outlet milik satu bisnis
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Relasi: Satu outlet bisa memiliki banyak produk
  products Product[]

  // Relasi: Banyak pesanan bisa dibuat di satu outlet
  orders Order[]

  // Relasi: Banyak pengeluaran bisa dicatat per outlet
  expenses Expense[]

  @@index([businessId])
}

// Model untuk produk (barang) atau jasa yang ditawarkan
model Product {
  id          String      @id @default(uuid())
  name        String
  description String?
  costPrice   Float       @default(0) // Harga Pokok Penjualan (HPP)
  price       Float // Harga Jual
  type        ProductType // Membedakan antara BARANG atau JASA
  quantity    Int? // Jumlah stok saat ini (untuk GOODS)
  unit        String? // Satuan (misal: Pcs, Kg, Box)

  // Status layanan (untuk on/off layanan)
  status ServiceStatus @default(ACTIVE)

  // Fee cas per produk (jika null, gunakan default dari Business)
  transactionFeeBearer FeeBearer?

  // Durasi layanan dalam menit (khusus untuk SERVICE)
  serviceDurationMinutes Int?

  // Relasi: Setiap produk/jasa terhubung ke satu outlet
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  image String? @default("https://png.pngtree.com/png-vector/20230808/ourmid/pngtree-goods-and-services-vector-png-image_6891390.png")

  // Relasi: Satu produk bisa ada di banyak item pesanan
  orderItems OrderItem[]

  // Relasi: Satu produk service bisa punya banyak booking slot
  bookingSlots BookingSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([outletId])
}

// Model untuk slot booking khusus layanan jasa
model BookingSlot {
  id        String            @id @default(uuid())
  date      DateTime // Tanggal booking
  startTime DateTime // Waktu mulai
  endTime   DateTime // Waktu selesai
  status    BookingSlotStatus @default(AVAILABLE)

  // Relasi: Slot ini untuk produk jasa mana
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Relasi: Slot ini dibooking oleh order mana (jika sudah dibooking)
  orderId String? @unique
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, startTime, endTime]) // Tidak boleh ada slot yang sama
  @@index([productId])
  @@index([date])
}

// Model untuk menyimpan data customer guest (tanpa register)
model GuestCustomer {
  id    String  @id @default(uuid())
  name  String
  email String?
  phone String?

  // Relasi: Satu guest customer bisa punya banyak order
  orders Order[]

  createdAt DateTime @default(now())

  @@index([email])
  @@index([phone])
}

// Model untuk pesanan/booking yang dibuat oleh customer
model Order {
  id          String    @id @default(uuid())
  totalAmount Int
  bookingDate DateTime? // Digunakan khusus untuk booking jasa

  // Tipe customer (registered atau guest)
  customerType CustomerType

  paymentStatus OrderPaymentStatus @default(PENDING)
  queueStatus   OrderQueueStatus   @default(AWAITING_PAYMENT)

  midtransTransactionToken   String? @unique
  midtransRedirectUrl        String?
  midtransTransactionDetails Json?

  // Relasi: Pesanan dibuat oleh registered customer (nullable)
  customerId String?
  customer   User?   @relation(fields: [customerId], references: [id], onDelete: Restrict)

  // Relasi: Pesanan dibuat oleh guest customer (nullable)
  guestCustomerId String?
  guestCustomer   GuestCustomer? @relation(fields: [guestCustomerId], references: [id], onDelete: Restrict)

  // Relasi: Pesanan dibuat di outlet mana
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Restrict)

  // Relasi: Satu pesanan punya banyak item
  items OrderItem[]

  // Relasi: Satu pesanan dibayar dengan satu transaksi
  transaction Transaction?

  // Relasi: Satu pesanan bisa book satu slot (untuk service)
  bookingSlot BookingSlot?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([guestCustomerId])
  @@index([outletId])
  @@index([bookingDate])
}

// Item-item yang ada di dalam sebuah pesanan
model OrderItem {
  id                 String @id @default(uuid())
  quantity           Int
  priceAtTimeOfOrder Float // Menyimpan harga saat itu untuk arsip

  // Relasi: Item ini bagian dari pesanan mana
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Relasi: Item ini merujuk ke produk apa
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

// Model untuk mencatat setiap transaksi pembayaran
model Transaction {
  id            String            @id @default(uuid())
  amount        Float
  paymentMethod String? // misal: "midtrans_qris", "midtrans_gopay"
  status        TransactionStatus @default(PENDING)
  externalId    String?           @unique // ID dari payment gateway (Midtrans)
  fee           Float // Biaya admin yang dikenakan
  adminFee      Float             @default(0)
  feePaidBy     String? // CUSTOMER / OWNER
  paidAt        DateTime?

  // Relasi: Transaksi ini untuk membayar pesanan mana
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// Model untuk dompet virtual milik bisnis
model Wallet {
  id      String @id @default(uuid())
  balance Float  @default(0)

  // Relasi: Dompet ini milik bisnis mana
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Relasi: Satu dompet bisa memiliki banyak riwayat penarikan
  withdrawals Withdrawal[]

  updatedAt DateTime @updatedAt
}

// Model untuk mencatat riwayat penarikan dana oleh owner
model Withdrawal {
  id              String           @id @default(uuid())
  amount          Float
  applicationFee  Float
  bankTransferFee Float
  status          WithdrawalStatus @default(PENDING)
  notes           String?

  // Relasi: Penarikan ini berasal dari dompet mana
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([walletId])
}

// Model untuk mencatat pengeluaran manual per outlet
model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Float
  date        DateTime

  // Relasi: Pengeluaran ini terjadi di outlet mana
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([outletId])
}

// Model untuk membership/keanggotaan customer di suatu bisnis
model Membership {
  id                 String     @id @default(uuid())
  memberCode         String     @unique
  memberType         MemberType @default(REGULAR)
  discountPercentage Float      @default(0)
  isActive           Boolean    @default(true)
  notes              String?

  // Relasi: Member ini milik customer mana
  customerId String
  customer   User   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Relasi: Member ini di bisnis mana
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerId, businessId])
  @@index([businessId])
  @@index([memberCode])
}
