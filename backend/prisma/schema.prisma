generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                  @id @default(uuid())
  email                   String                  @unique
  name                    String
  avatar                  String?
  password                String
  role                    UserRole                @default(OWNER)
  status                  UserStatus              @default(ACTIVE)
  isVerified              Boolean                 @default(false)
  verificationCode        String?
  verificationCodeExpires DateTime?
  phone                   String?
  googleId                String?                 @unique
  provider                String?                 @default("local")
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  business                Business?
  receivedTransfers       OutletTransferRequest[] @relation("ReceivedTransfers")
  sentTransfers           OutletTransferRequest[] @relation("SentTransfers")
  pushSubscriptions       PushSubscription[]
  transactionsVerified    Transaction[]           @relation("TransactionVerifiedBy")
  auditLogs               AuditLog[]              @relation("AuditPerformedBy")
  reports                 Report[]

  @@index([email])
  @@index([role])
  @@index([status])
}

model PushSubscription {
  id              String         @id @default(uuid())
  endpoint        String         @unique
  p256dh          String
  auth            String
  guestCustomerId String?
  userId          String?
  staffId         String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  guestCustomer   GuestCustomer? @relation(fields: [guestCustomerId], references: [id], onDelete: Cascade)
  staff           Staff?         @relation(fields: [staffId], references: [id], onDelete: Cascade)
  user            User?          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guestCustomerId])
  @@index([userId])
  @@index([staffId])
}

model Business {
  id                    String                 @id @default(uuid())
  name                  String
  description           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  bankName              String?
  bankAccount           String?
  accountHolder         String?
  currentSubscriptionId String?                @unique
  subscriptionStatus    SubscriptionStatus     @default(ACTIVE)
  subscriptionStartDate DateTime               @default(now())
  subscriptionEndDate   DateTime?
  subscriptionPlan      String                 @default("BASIC")
  ownerId               String                 @unique
  banners               Banner[]
  currentSubscription   BusinessSubscription?  @relation("ActiveSubscription", fields: [currentSubscriptionId], references: [id])
  owner                 User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  subscriptions         BusinessSubscription[] @relation("BusinessHistory")
  outlets               Outlet[]
  subscriptionInvoices  SubscriptionInvoice[]
  stockTransfers        StockTransfer[]
  accounts              Account[]
  journalEntries        JournalEntry[]
  integrations          Integration[]

  @@index([ownerId])
  @@index([subscriptionStatus])
  @@index([description])
}

model SubscriptionPlan {
  id             String                 @id @default(uuid())
  name           String
  code           String                 @unique
  promo          String?
  price          Float
  durationDays   Int
  yearlyPrice    Float                  @default(0)
  yearlyDiscount Int                    @default(0)
  features       Json
  isActive       Boolean                @default(true)
  isPopular      Boolean                @default(false)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  subscriptions  BusinessSubscription[]
}

model BusinessSubscription {
  id                String                @id @default(uuid())
  status            SubscriptionStatus
  startDate         DateTime              @default(now())
  endDate           DateTime
  billingCycle      Int                   @default(30)
  pricePerCycle     Float                 @default(0)
  nextBillingDate   DateTime?
  businessId        String
  planId            String
  autoRenew         Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  activeForBusiness Business?             @relation("ActiveSubscription")
  business          Business              @relation("BusinessHistory", fields: [businessId], references: [id], onDelete: Cascade)
  plan              SubscriptionPlan      @relation(fields: [planId], references: [id])
  invoices          SubscriptionInvoice[]

  @@index([businessId])
  @@index([endDate])
  @@index([nextBillingDate])
}

model SubscriptionInvoice {
  id              String                @id @default(uuid())
  invoiceNumber   String                @unique
  amount          Float
  status          PaymentStatus
  paymentUrl      String?
  externalId      String?
  proofImage      String?
  proofUploadedAt DateTime?
  verifiedAt      DateTime?
  rejectionReason String?
  paidAt          DateTime?
  businessId      String?
  subscriptionId  String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  business        Business?             @relation(fields: [businessId], references: [id])
  subscription    BusinessSubscription? @relation(fields: [subscriptionId], references: [id])

  @@index([createdAt])
}

model Outlet {
  id                  String     @id @default(uuid())
  name                String
  slug                String     @unique
  description         String?
  address             String?
  phone               String?
  instagramUrl        String?
  email               String?    @unique
  createdAt           DateTime   @default(now())
  image               String?    @default("/defaults/default-outlet-image.webp")
  updatedAt           DateTime   @updatedAt
  latitude            Float?
  longitude           Float?
  isOpen              Boolean    @default(false)
  businessId          String
  manualBankName      String?
  manualBankAccount   String?
  manualAccountHolder String?
  manualPaymentNote   String?
  manualQrImageUrl    String?
  qrisString          String?
  type                OutletType @default(CUSTOM)

  loyaltyConfig             LoyaltyConfig?
  pointHistories            LoyaltyPointHistory[]
  loyaltyTiers              LoyaltyTier[]
  loyaltyRewards            LoyaltyReward[]
  rewardRedemptions         RewardRedemption[]
  orders                    Order[]
  cashierShifts             CashierShift[]
  business                  Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  memberships               OutletMembership[]
  operatingHours            OutletOperatingHours[]
  tables                    OutletTable[]
  transferRequests          OutletTransferRequest[]
  products                  Product[]
  staff                     Staff[]
  expenses                  Expense[]
  receiptSettings           receiptSetting?
  suppliers                 Supplier[]
  transactionDeleteRequests TransactionDeleteRequest[]
  productCategories         ProductCategory[]
  attendances               Attendance[]
  ingredients               Ingredient[]
  purchaseOrders            PurchaseOrder[]
  sentStockTransfers        StockTransfer[]            @relation("SentStockTransfers")
  receivedStockTransfers    StockTransfer[]            @relation("ReceivedStockTransfers")

  @@index([businessId])
  @@index([slug])
  @@index([latitude, longitude])
  @@index([name])
  @@index([description])
}

model OutletTable {
  id        String      @id @default(uuid())
  name      String
  capacity  Int         @default(2)
  status    TableStatus @default(AVAILABLE)
  note      String?
  outletId  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  bills     Bill[]
  orders    Order[]
  outlet    Outlet      @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId])
}

model OutletTransferRequest {
  id         String         @id @default(uuid())
  outletId   String
  senderId   String
  receiverId String
  status     TransferStatus @default(PENDING)
  note       String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  outlet     Outlet         @relation(fields: [outletId], references: [id], onDelete: Cascade)
  receiver   User           @relation("ReceivedTransfers", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User           @relation("SentTransfers", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([outletId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model OutletOperatingHours {
  id         String    @id @default(uuid())
  dayOfWeek  Int
  openTime   DateTime
  closeTime  DateTime
  breakStart DateTime?
  breakEnd   DateTime?
  isOpen     Boolean   @default(true)
  outletId   String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  outlet     Outlet    @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([outletId, dayOfWeek])
  @@index([outletId])
}

model Staff {
  id                        String                     @id @default(uuid())
  name                      String
  phone                     String?
  username                  String?                    @unique
  email                     String?
  pin                       String?
  faceImageUrl              String?
  faceDescriptor            String?
  role                      StaffRole                  @default(CASHIER)
  status                    StaffStatus                @default(ACTIVE)
  outletId                  String
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  ordersHandled             Order[]
  pushSubscriptions         PushSubscription[]
  cashierShifts             CashierShift[]
  outlet                    Outlet                     @relation(fields: [outletId], references: [id], onDelete: Cascade)
  ticketCodesRedeemed       TicketCode[]
  transactionDeleteRequests TransactionDeleteRequest[]
  attendances               Attendance[]
  privileges                StaffPrivilege[]

  @@index([outletId])
  @@index([username])
  @@index([role])
  @@index([name])
}

model StaffPrivilege {
  id        String             @id @default(uuid())
  staffId   String
  privilege StaffPrivilegeType
  createdAt DateTime           @default(now())
  staff     Staff              @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, privilege])
  @@index([staffId])
}

model Product {
  id                 String              @id @default(uuid())
  name               String
  description        String?
  type               ProductType
  status             ServiceStatus       @default(ACTIVE)
  outletId           String
  categoryId         String?
  image              String?             @default("/defaults/default-product-image.png")
  taxPercentage      Float?
  taxName            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  orderItems         OrderItem[]
  outlet             Outlet              @relation(fields: [outletId], references: [id], onDelete: Cascade)
  category           ProductCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  goods              ProductGoods?
  media              ProductMedia[]
  service            ProductService?
  ticket             ProductTicket?
  recipe             Recipe?
  stockTransferItems StockTransferItem[]

  @@index([outletId])
  @@index([type])
  @@index([status])
  @@index([categoryId])
}

model ProductCategory {
  id        String    @id @default(uuid())
  name      String
  outletId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  outlet    Outlet    @relation(fields: [outletId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([name, outletId])
  @@index([outletId])
}

model ProductMedia {
  id           String      @id @default(uuid())
  productId    String
  url          String
  type         MediaType   @default(IMAGE)
  source       MediaSource @default(UPLOAD)
  alt          String?
  order        Int         @default(0)
  thumbnailUrl String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, order])
}

model ProductGoods {
  id                 String              @id @default(uuid())
  productId          String              @unique
  currentStock       Int                 @default(0)
  minStock           Int?
  maxStock           Int?
  unit               String
  averageHpp         Float               @default(0)
  sellingPrice       Float
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  barcode            String?             @unique
  sku                String?
  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockLogs          StockLog[]
  suppliers          SupplierProduct[]
  batches            GoodsStockBatch[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([barcode])
  @@index([productId])
  @@index([currentStock])
}

// Model Batch Stok Masuk Retail (Mendukung FIFO)
model GoodsStockBatch {
  id                String    @id @default(uuid())
  productGoodsId    String
  purchaseQuantity  Int // Kuantitas awal yang dibeli
  remainingQuantity Int // Kuantitas yang tersisa untuk dikonsumsi
  costPerUnit       Float // Harga beli per unit (HPP unit dari batch tersebut)
  expiryDate        DateTime? // Tanggal kedaluwarsa barang
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  productGoods ProductGoods @relation(fields: [productGoodsId], references: [id], onDelete: Cascade)

  @@index([productGoodsId])
  @@index([createdAt]) // Diperlukan untuk pengurutan FIFO (oldest first)
}

model Supplier {
  id             String            @id @default(uuid())
  name           String
  phone          String?
  email          String?
  address        String?
  notes          String?
  outletId       String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  outlet         Outlet            @relation(fields: [outletId], references: [id], onDelete: Cascade)
  products       SupplierProduct[]
  purchaseOrders PurchaseOrder[]

  @@index([outletId])
  @@index([name])
}

model SupplierProduct {
  id             String       @id @default(uuid())
  supplierId     String
  productGoodsId String
  lastPrice      Float?
  lastOrderDate  DateTime?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  supplier       Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  productGoods   ProductGoods @relation(fields: [productGoodsId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productGoodsId])
  @@index([supplierId])
  @@index([productGoodsId])
}

model ProductService {
  id                 String        @id @default(uuid())
  productId          String        @unique
  durationMinutes    Int
  sellingPrice       Float
  providerName       String
  providerPhone      String?
  providerEmail      String?
  commissionType     String        @default("PERCENTAGE")
  commissionValue    Float         @default(0)
  maxParallel        Int           @default(1)
  bookingInWorkHours Boolean       @default(true)
  mondayOpen         DateTime?
  mondayClose        DateTime?
  tuesdayOpen        DateTime?
  tuesdayClose       DateTime?
  wednesdayOpen      DateTime?
  wednesdayClose     DateTime?
  thursdayOpen       DateTime?
  thursdayClose      DateTime?
  fridayOpen         DateTime?
  fridayClose        DateTime?
  saturdayOpen       DateTime?
  saturdayClose      DateTime?
  sundayOpen         DateTime?
  sundayClose        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  bookingSlots       BookingSlot[]
  product            Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([providerName])
}

enum TicketCodeFormat {
  QR_CODE
  BARCODE_128
}

model ProductTicket {
  id            String           @id @default(uuid())
  productId     String           @unique
  sellingPrice  Float
  eventDate     DateTime
  eventEndDate  DateTime?
  venue         String
  venueAddress  String?
  mapUrl        String?
  totalQuota    Int
  soldCount     Int              @default(0)
  maxPerOrder   Int              @default(5)
  saleStartDate DateTime?
  saleEndDate   DateTime?
  terms         String?
  codeFormat    TicketCodeFormat @default(QR_CODE)
  designConfig  Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  product       Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([eventDate])
  @@index([soldCount])
}

model StockLog {
  id             String            @id @default(uuid())
  type           StockMovementType
  quantity       Int
  hppPerUnit     Float?
  referenceType  String?
  referenceId    String?
  notes          String?
  productGoodsId String
  faktur         String?
  createdAt      DateTime          @default(now())
  productGoods   ProductGoods      @relation(fields: [productGoodsId], references: [id], onDelete: Cascade)

  @@index([productGoodsId])
  @@index([type])
  @@index([createdAt])
  @@index([referenceType, referenceId])
}

model BookingSlot {
  id                    String            @id @default(uuid())
  date                  DateTime
  startTime             DateTime
  endTime               DateTime
  status                BookingSlotStatus @default(AVAILABLE)
  reminderSent          Boolean           @default(false)
  productServiceId      String
  orderItemId           String?           @unique
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  order                 OrderItem?        @relation(fields: [orderItemId], references: [id])
  productService        ProductService    @relation(fields: [productServiceId], references: [id], onDelete: Cascade)
  googleCalendarEventId String?

  @@index([productServiceId])
  @@index([date])
  @@index([status])
}

model GuestCustomer {
  id                String                @id @default(uuid())
  name              String
  email             String?
  phone             String                @unique
  address           String?
  notes             String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @default(now()) @updatedAt
  pointHistories    LoyaltyPointHistory[]
  memberships       Membership[]
  orders            Order[]
  outletMemberships OutletMembership[]
  rewardRedemptions RewardRedemption[]
  pushSubscriptions PushSubscription[]

  @@index([email])
  @@index([phone])
}

model CashierShift {
  id            String         @id @default(uuid())
  status        ShiftStatus    @default(OPEN)
  outletId      String
  staffId       String
  openedAt      DateTime       @default(now())
  closedAt      DateTime?
  openingCash   Float          @default(0)
  closingCash   Float?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  outlet        Outlet         @relation(fields: [outletId], references: [id], onDelete: Cascade)
  staff         Staff          @relation(fields: [staffId], references: [id], onDelete: Cascade)
  orders        Order[]
  transactions  Transaction[]
  cashMovements CashMovement[]

  @@index([outletId, status])
  @@index([staffId, status])
  @@index([openedAt])
}

model CashMovement {
  id        String           @id @default(uuid())
  type      CashMovementType
  amount    Float
  note      String?
  shiftId   String
  createdAt DateTime         @default(now())
  shift     CashierShift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([shiftId, createdAt])
  @@index([type])
}

model LoyaltyConfig {
  id               String   @id @default(uuid())
  outletId         String   @unique
  pointsEarned     Int      @default(1)
  multiplierAmount Float    @default(10000)
  minSpending      Float    @default(0)
  pointValue       Float    @default(0) // legacy: nilai 1 poin dalam Rp (jika tidak pakai reward catalog)
  isActive         Boolean  @default(true)
  // Enhancement fields
  autoEnroll       Boolean  @default(true) // otomatis daftarkan pelanggan saat transaksi pertama
  welcomeBonus     Int      @default(0) // poin bonus untuk member baru
  maxRedeemPercent Float    @default(100) // maks % dari total belanja yang bisa dibayar pakai poin
  expiryDays       Int? // hari sebelum poin hangus (null = tidak pernah)
  minRedeemPoints  Int      @default(1) // minimum poin untuk sekali penukaran
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  outlet           Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
}

model LoyaltyTier {
  id                String             @id @default(uuid())
  outletId          String
  name              String // "Bronze", "Silver", "Gold", dll
  color             String             @default("#CD7F32") // hex color
  minLifetimePoints Int                @default(0) // min lifetime points untuk tier ini
  earnMultiplier    Float              @default(1.0) // 2.0 = 2x poin
  sortOrder         Int                @default(0) // urutan tier (makin kecil = makin rendah)
  benefits          String? // deskripsi benefit tier (teks bebas)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  outlet            Outlet             @relation(fields: [outletId], references: [id], onDelete: Cascade)
  memberships       OutletMembership[]

  @@unique([outletId, name])
  @@index([outletId])
}

model LoyaltyReward {
  id              String             @id @default(uuid())
  outletId        String
  name            String
  description     String?
  imageUrl        String?
  type            LoyaltyRewardType
  pointsCost      Int // poin yang dibutuhkan untuk redeem reward ini
  // Tipe-spesifik
  discountAmount  Float? // untuk DISCOUNT_FLAT (Rp)
  discountPercent Float? // untuk DISCOUNT_PERCENT (%)
  maxDiscount     Float? // batas maksimum diskon untuk DISCOUNT_PERCENT
  productId       String? // untuk FREE_ITEM
  voucherValue    Float? // untuk VOUCHER
  cashbackAmount  Float? // untuk CASHBACK
  // Ketersediaan
  stock           Int                @default(-1) // -1 = tidak terbatas
  isActive        Boolean            @default(true)
  validFrom       DateTime?
  validUntil      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  outlet          Outlet             @relation(fields: [outletId], references: [id], onDelete: Cascade)
  redemptions     RewardRedemption[]

  @@index([outletId])
  @@index([outletId, isActive])
}

model RewardRedemption {
  id              String                 @id @default(uuid())
  outletId        String
  guestCustomerId String
  loyaltyRewardId String
  orderId         String?
  pointsUsed      Int
  status          RewardRedemptionStatus @default(PENDING)
  note            String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  outlet          Outlet                 @relation(fields: [outletId], references: [id], onDelete: Cascade)
  guestCustomer   GuestCustomer          @relation(fields: [guestCustomerId], references: [id], onDelete: Cascade)
  loyaltyReward   LoyaltyReward          @relation(fields: [loyaltyRewardId], references: [id], onDelete: Cascade)

  @@index([outletId])
  @@index([guestCustomerId])
  @@index([orderId])
}

model OutletMembership {
  id              String        @id @default(uuid())
  guestCustomerId String
  outletId        String
  totalPoints     Int           @default(0) // poin aktif yang bisa dipakai
  lifetimePoints  Int           @default(0) // akumulasi poin sepanjang masa (untuk kalkulasi tier)
  totalSpending   Float         @default(0)
  status          String        @default("ACTIVE")
  tierId          String? // cached current tier
  joinedAt        DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  guestCustomer   GuestCustomer @relation(fields: [guestCustomerId], references: [id], onDelete: Cascade)
  outlet          Outlet        @relation(fields: [outletId], references: [id], onDelete: Cascade)
  tier            LoyaltyTier?  @relation(fields: [tierId], references: [id])

  @@unique([guestCustomerId, outletId])
  @@index([guestCustomerId])
  @@index([outletId])
  @@index([tierId])
}

model LoyaltyPointHistory {
  id              String                  @id @default(uuid())
  outletId        String
  guestCustomerId String
  orderId         String?
  type            LoyaltyPointHistoryType
  points          Int
  note            String?
  createdAt       DateTime                @default(now())
  guestCustomer   GuestCustomer           @relation(fields: [guestCustomerId], references: [id], onDelete: Cascade)
  order           Order?                  @relation(fields: [orderId], references: [id])
  outlet          Outlet                  @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId, guestCustomerId, createdAt])
  @@index([orderId])
}

model Order {
  id                       String                    @id @default(uuid())
  totalAmount              Float
  taxAmount                Float                     @default(0)
  discountAmount           Float                     @default(0)
  pointsRedeemed           Int                       @default(0)
  bookingDate              DateTime?
  bookingDurationMinutes   Int?
  guestCount               Int?
  customerType             CustomerType              @default(GUEST)
  paymentStatus            PaymentStatus             @default(PENDING)
  paymentReminderSent      Boolean                   @default(false)
  orderStatus              OrderStatus               @default(AWAITING_PAYMENT)
  notes                    String?
  cancellationReason       String?
  midtransTransactionToken String?                   @unique
  midtransRedirectUrl      String?
  midtransFee              Float                     @default(0)
  appFee                   Float                     @default(0)
  guestCustomerId          String
  outletId                 String
  handledByStaffId         String?
  cashierShiftId           String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  tableNumber              String?
  tableId                  String?
  billId                   String?
  pointHistories           LoyaltyPointHistory[]
  memberships              Membership[]
  bill                     Bill?                     @relation(fields: [billId], references: [id])
  guestCustomer            GuestCustomer             @relation(fields: [guestCustomerId], references: [id], onDelete: Cascade)
  handledByStaff           Staff?                    @relation(fields: [handledByStaffId], references: [id])
  cashierShift             CashierShift?             @relation(fields: [cashierShiftId], references: [id])
  outlet                   Outlet                    @relation(fields: [outletId], references: [id], onDelete: Cascade)
  table                    OutletTable?              @relation(fields: [tableId], references: [id])
  items                    OrderItem[]
  transaction              Transaction?
  deleteRequest            TransactionDeleteRequest?

  @@index([guestCustomerId])
  @@index([outletId])
  @@index([bookingDate])
  @@index([handledByStaffId])
  @@index([cashierShiftId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([tableId])
  @@index([billId])
}

model Bill {
