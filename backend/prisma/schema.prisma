// This is your Prisma schema file,
// learn more about it in the docs: https://pris.lyd/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// ENUMS - Untuk memastikan konsistensi data
// =============================================

enum Role {
  OWNER // Pemilik UMKM
  CUSTOMER // Pelanggan biasa
}

enum ProductType {
  GOODS // Produk barang yang memiliki stok
  SERVICE // Layanan jasa
}

enum OrderPaymentStatus {
  PENDING // Menunggu pembayaran atau belum ada konfirmasi dari Midtrans
  SUCCESS // Pembayaran berhasil (settlement/capture)
  FAILURE // Pembayaran gagal (deny/expire/cancel)
  REFUNDED // Pembayaran dikembalikan
  CHALLENGE // Pembayaran dalam sengketa/investigasi
  CANCELLED_BY_SYSTEM // Dibatalkan oleh sistem (misal: melewati batas waktu)
  UNKNOWN // Status tidak dikenal
}

enum OrderQueueStatus {
  CREATED // Pesanan baru dibuat, belum diproses lebih lanjut
  AWAITING_PAYMENT // Pesanan menunggu konfirmasi pembayaran
  IN_QUEUE // Pembayaran berhasil, pesanan jasa masuk antrian
  READY_FOR_PICKUP // Pembayaran berhasil, barang fisik siap diambil
  IN_PROGRESS // Jasa sedang dikerjakan atau barang sedang disiapkan
  COMPLETED // Jasa/barang selesai diproses/diambil
  CANCELLED // Pesanan dibatalkan (misal oleh customer)
  REFUNDED // Pesanan direfund
  FAILED_PROCESSING // Gagal diproses setelah pembayaran
  UNKNOWN
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum WithdrawalStatus {
  PENDING
  COMPLETED
  REJECTED
}

// === Enum untuk Siapa yang Menanggung Biaya ===
enum FeeBearer {
  CUSTOMER
  OWNER
}

// Model untuk pengguna, baik Owner maupun Customer
model User {
  id                      String    @id @default(cuid())
  email                   String    @unique
  name                    String
  avatar                  String?
  password                String // Akan disimpan dalam bentuk hash
  role                    Role      @default(CUSTOMER)
  isVerified              Boolean   @default(false)
  verificationCode        String?
  verificationCodeExpires DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Relasi: Satu user (owner) bisa memiliki banyak bisnis
  businesses Business[]

  // Relasi: Satu user (customer) bisa membuat banyak pesanan
  orders Order[]

  @@index([email])
}

// Model untuk entitas bisnis utama milik seorang Owner
model Business {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relasi: Setiap bisnis dimiliki oleh satu User (Owner)
  bankName      String?
  bankAccount   String?
  accountHolder String?

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Relasi: Satu bisnis bisa memiliki banyak outlet
  outlets Outlet[]

  // Relasi: Satu bisnis bisa memiliki banyak jenis produk/jasa
  products Product[]

  // Relasi: Setiap bisnis memiliki satu dompet virtual
  wallet Wallet?

  // Menentukan siapa yang menanggung biaya Midtrans untuk transaksi QRIS/booking
  defaultTransactionFeeBearer FeeBearer @default(OWNER) // Defaultnya owner yang menanggung

  @@index([ownerId])
}

// Model untuk cabang/outlet dari sebuah bisnis
model Outlet {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi: Setiap outlet milik satu bisnis
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Relasi: Satu outlet memiliki banyak data stok
  stocks Stock[]

  // Relasi: Banyak pesanan bisa dibuat di satu outlet
  orders Order[]

  // Relasi: Banyak pengeluaran bisa dicatat per outlet
  expenses Expense[]

  @@index([businessId])
}

// Model untuk produk (barang) atau jasa yang ditawarkan
model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  price       Float // Harga Jual
  type        ProductType // Membedakan antara BARANG atau JASA

  // Relasi: Setiap produk/jasa terhubung ke satu bisnis
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Relasi: Satu produk bisa ada di banyak data stok (di outlet berbeda)
  stockEntries Stock[]

  // Relasi: Satu produk bisa ada di banyak item pesanan
  orderItems OrderItem[]

  @@index([businessId])
}

// Tabel pivot untuk manajemen stok per produk per outlet
model Stock {
  id        String @id @default(cuid())
  quantity  Int // Jumlah stok saat ini
  unit      String // Satuan (misal: Pcs, Kg, Box)
  costPrice Float // Harga Pokok Penjualan (HPP)

  // Relasi: Stok ini untuk produk apa
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Relasi: Stok ini berada di outlet mana
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  // Memastikan satu produk hanya punya satu entri stok per outlet
  @@unique([productId, outletId])
}

// Model untuk pesanan/booking yang dibuat oleh customer
model Order {
  id          String    @id @default(cuid())
  totalAmount Int
  bookingDate DateTime? // Digunakan khusus untuk booking jasa

  paymentStatus OrderPaymentStatus @default(PENDING) // lebih spesifik untuk pembayaran
  queueStatus   OrderQueueStatus   @default(AWAITING_PAYMENT) // Status antrian/proses order

  midtransTransactionToken   String? @unique // Token dari Midtrans Snap (untuk popup)
  midtransRedirectUrl        String? // URL redirect dari Midtrans Snap (untuk redirect browser)
  midtransTransactionDetails Json? // Menyimpan seluruh payload notifikasi dari Midtrans (opsional tapi disarankan)

  // Relasi: Pesanan dibuat oleh siapa (customer)
  customerId String
  customer   User   @relation(fields: [customerId], references: [id], onDelete: Restrict)

  // Relasi: Pesanan dibuat di outlet mana
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Restrict)

  // Relasi: Satu pesanan punya banyak item
  items OrderItem[]

  // Relasi: Satu pesanan dibayar dengan satu transaksi (tetap)
  transaction Transaction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([outletId])
}

// Item-item yang ada di dalam sebuah pesanan
model OrderItem {
  id                 String @id @default(cuid())
  quantity           Int
  priceAtTimeOfOrder Float // Menyimpan harga saat itu untuk arsip

  // Relasi: Item ini bagian dari pesanan mana
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Relasi: Item ini merujuk ke produk apa
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

// Model untuk mencatat setiap transaksi pembayaran (Midtrans, QRIS)
model Transaction {
  id            String            @id @default(cuid())
  amount        Float
  paymentMethod String // misal: "midtrans_qris", "midtrans_gopay"
  status        TransactionStatus @default(PENDING)
  externalId    String?           @unique // ID dari payment gateway (Midtrans)
  fee           Float // Biaya admin yang dikenakan (misal: 2%)
  adminFee      Float             @default(0)
  feePaidBy     String? // CUSTOMER / OWNER (Ini akan diisi dari konfigurasi Business)

  // Relasi: Transaksi ini untuk membayar pesanan mana
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// Model untuk dompet virtual milik bisnis
model Wallet {
  id      String @id @default(cuid())
  balance Float  @default(0)

  // Relasi: Dompet ini milik bisnis mana (satu-ke-satu)
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Relasi: Satu dompet bisa memiliki banyak riwayat penarikan
  withdrawals Withdrawal[]

  updatedAt DateTime @updatedAt
}

// Model untuk mencatat riwayat penarikan dana oleh owner
model Withdrawal {
  id              String           @id @default(cuid())
  amount          Float // Jumlah yang ditarik owner
  applicationFee  Float // Potongan 2% untuk aplikasi
  bankTransferFee Float // Potongan Rp 4.000 untuk bank
  status          WithdrawalStatus @default(PENDING)
  notes           String? // Catatan, misal nomor rekening tujuan

  // Relasi: Penarikan ini berasal dari dompet mana
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([walletId])
}

// Model untuk mencatat pengeluaran manual per outlet
model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  date        DateTime

  // Relasi: Pengeluaran ini terjadi di outlet mana
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([outletId])
}
