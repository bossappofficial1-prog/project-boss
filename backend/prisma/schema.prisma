// Enum untuk pergerakan stok bahan baku
enum IngredientStockLogType {
  IN
  OUT
  ADJUSTMENT
  POS_DEDUCTION
  SPOILAGE
}

// Model Bahan Baku
model Ingredient {
  id               String   @id @default(uuid())
  name             String
  purchaseUnit     String // Misal: kg, Liter, Box
  recipeUnit       String // Misal: gram, ml, pcs
  conversionFactor Float    @default(1) // Pengali beli-ke-resep. Contoh: 1 kg -> 1000 g (factor = 1000)
  currentStock     Float    @default(0) // Total stok dalam satuan resep (recipeUnit)
  averageCost      Float    @default(0) // Estimasi harga saat ini per unit resep (untuk perhitungan HPP visual)
  minStock         Float?
  outletId         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  outlet             Outlet                 @relation(fields: [outletId], references: [id], onDelete: Cascade)
  batches            IngredientStockBatch[]
  recipes            RecipeIngredient[]
  stockLogs          IngredientStockLog[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([outletId])
}

// Model Batch Stok Masuk (Mendukung FIFO)
model IngredientStockBatch {
  id                String    @id @default(uuid())
  ingredientId      String
  purchaseQuantity  Float // Kuantitas awal yang dibeli (dalam satuan resep)
  remainingQuantity Float // Kuantitas yang tersisa untuk dikonsumsi (dalam satuan resep)
  costPerRecipeUnit Float // Harga beli per unit resep (total_cost / (qty_beli * factor))
  expiryDate        DateTime? // Tanggal kedaluwarsa bahan baku
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([ingredientId])
  @@index([createdAt]) // Diperlukan untuk pengurutan FIFO (oldest first)
}

// Model Resep Menu (Terhubung 1-to-1 dengan Product)
model Recipe {
  id        String   @id @default(uuid())
  productId String   @unique
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product     Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]
}

// Tabel Junction antara Resep dan Bahan Baku beserta kuantitasnya
model RecipeIngredient {
  id           String @id @default(uuid())
  recipeId     String
  ingredientId String
  quantity     Float // Jumlah bahan baku (dalam satuan resep) yang digunakan dalam resep ini

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
  @@index([recipeId])
  @@index([ingredientId])
}

// Riwayat Pergerakan Stok Bahan Baku
model IngredientStockLog {
  id           String                 @id @default(uuid())
  ingredientId String
  type         IngredientStockLogType
  quantity     Float // Jumlah dalam satuan resep (masuk +, keluar -)
  costPerUnit  Float? // Harga beli per unit resep jika tipe IN
  referenceId  String? // ID pesanan atau ID PO jika ada
  notes        String?
  createdAt    DateTime               @default(now())

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([ingredientId])
}

