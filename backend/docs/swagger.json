{
    "openapi": "3.0.0",
    "info": {
        "title": "Dokumentasi API BOSS",
        "version": "1.0.0",
        "description": "Dokumentasi API BOSS"
    },
    "servers": [
        {
            "url": "http://localhost:4444/api/v1"
        }
    ],
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        }
    },
    "paths": {
        "/auth/login": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "requestBody": {
                    "required": true,
                    "description": "Payload untuk login",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "email": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "email",
                                    "password"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Berhasil login"
                    },
                    "400": {
                        "description": "validasi Request"
                    }
                }
            }
        },
        "/auth/register": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "requestBody": {
                    "required": true,
                    "description": "Payload untuk register",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "email": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    },
                                    "name": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "email",
                                    "password",
                                    "name"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Berhasil register"
                    },
                    "400": {
                        "description": "validasi Request"
                    }
                }
            }
        },
        "/auth/me": {
            "get": {
                "tags": [
                    "Authentication"
                ],
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Info user yang sedang login"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            },
            "patch": {
                "tags": [
                    "Authentication"
                ],
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "token"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Berhasil memperbarui profile"
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "400": {
                        "description": "Bad request"
                    }
                }
            }
        },
        "/auth/login-google": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "token": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "token"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login sukses"
                    },
                    "400": {
                        "description": "Bad Request"
                    }
                }
            }
        },
        "/auth/resend-otp": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "email": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "email"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Berhasil mengirim ulang kode OTP"
                    },
                    "400": {
                        "description": "Bad Request"
                    }
                }
            }
        },
        "/auth/verify-otp": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "email": {
                                        "type": "string"
                                    },
                                    "otp": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "email"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Akun berhasil diverifikasi!"
                    },
                    "400": {
                        "description": "Bad Request"
                    }
                }
            }
        },
        "/businesses": {
            "get": {
                "tags": [
                    "Business"
                ],
                "summary": "List bisnis untuk landing page",
                "description": "Mengambil daftar bisnis UMKM.",
                "responses": {
                    "200": {
                        "description": "Berhasil ambil daftar bisnis",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "id": {
                                                "type": "string",
                                                "example": "ckv123abc"
                                            },
                                            "name": {
                                                "type": "string",
                                                "example": "Toko Kopi Abah"
                                            },
                                            "description": {
                                                "type": "string",
                                                "example": "Jual kopi dan alat seduh"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/businesses/{id}/products": {
            "get": {
                "tags": [
                    "Business"
                ],
                "summary": "List produk/jasa dari bisnis",
                "description": "Mengambil daftar produk/jasa dari bisnis berdasarkan ID.",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "description": "ID bisnis"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Berhasil ambil daftar produk/jasa",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "id": {
                                                "type": "string",
                                                "example": "prod1"
                                            },
                                            "name": {
                                                "type": "string",
                                                "example": "Kopi Arabica 250gr"
                                            },
                                            "description": {
                                                "type": "string",
                                                "example": "Biji kopi arabica pilihan"
                                            },
                                            "price": {
                                                "type": "number",
                                                "example": 75000
                                            },
                                            "type": {
                                                "type": "string",
                                                "example": "GOODS"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Bisnis tidak ditemukan",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Bisnis tidak ditemukan"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/businesses/{id}/detail": {
            "get": {
                "tags": [
                    "Business"
                ],
                "summary": "Detail bisnis + outlet + produk/jasa",
                "description": "Mengambil detail bisnis beserta outlet dan produk/jasa yang tersedia.",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "description": "ID bisnis"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Detail bisnis berhasil diambil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "id": {
                                            "type": "string",
                                            "example": "ckv123abc"
                                        },
                                        "name": {
                                            "type": "string",
                                            "example": "Toko Kopi Abah"
                                        },
                                        "description": {
                                            "type": "string",
                                            "example": "Jual kopi dan alat seduh"
                                        },
                                        "outlets": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "id": {
                                                        "type": "string",
                                                        "example": "outlet1"
                                                    },
                                                    "name": {
                                                        "type": "string",
                                                        "example": "Outlet Pusat"
                                                    },
                                                    "address": {
                                                        "type": "string",
                                                        "example": "Jl. Raya No.1"
                                                    }
                                                }
                                            }
                                        },
                                        "products": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "id": {
                                                        "type": "string",
                                                        "example": "prod1"
                                                    },
                                                    "name": {
                                                        "type": "string",
                                                        "example": "Kopi Arabica 250gr"
                                                    },
                                                    "description": {
                                                        "type": "string",
                                                        "example": "Biji kopi arabica pilihan"
                                                    },
                                                    "price": {
                                                        "type": "number",
                                                        "example": 75000
                                                    },
                                                    "type": {
                                                        "type": "string",
                                                        "example": "GOODS"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Bisnis tidak ditemukan",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Bisnis tidak ditemukan"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}