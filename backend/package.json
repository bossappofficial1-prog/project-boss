{
  "name": "boss-backend",
  "version": "1.0.0",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun run build:clean && swc src --out-dir dist --copy-files",
    "build:clean": "rm -rf dist",
    "start": "bun dist/src/index.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "db:migrate": "bunx prisma migrate dev",
    "db:generate": "bunx prisma generate",
    "db:seed": "bun prisma/db/seed.ts",
    "db:seed:force": "bun prisma/db/seed.ts --force",
    "db:studio": "bunx prisma studio",
    "db:reset": "bunx prisma migrate reset --force",
    "db:prepare": "bunx prisma generate",
    "docs:install": "bun install redoc-cli@^0.13.21",
    "docs:generate": "bunx redoc-cli build openapi.json --output docs/index.html --title 'BOSS API Documentation'",
    "docs:serve": "bunx redoc-cli serve openapi.json --watch --port 8080",
    "socket:test": "bun test-socket.js",
    "socket:test-public": "bun test-socket-public.js",
    "elastic:test": "bun test-elastic.js test",
    "elastic:setup": "bun test-elastic.js setup",
    "elastic:search": "bun test-elastic.js search",
    "test:type": "bunx tsc --noEmit",
    "typecheck": "bunx tsc --noEmit"
  },
  "prisma": {
    "seed": "bun run db:seed"
  },
  "keywords": [
    "service",
    "express",
    "backend",
    "docker"
  ],
  "dependencies": {
    "@elastic/elasticsearch": "^8.15.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "amqplib": "^0.10.8",
    "axios": "^1.10.0",
    "bcryptjs": "^3.0.2",
    "bull": "^4.16.5",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.0.1",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.3.3",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "midtrans-client": "^1.4.3",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^7.0.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.17.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-roll": "^4.0.0",
    "puppeteer-core": "^24.40.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "twilio": "^5.7.3",
    "web-push": "^3.6.7",
    "xendit-node": "^7.0.0",
    "zod": "^3.25.74"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.5",
    "@types/amqplib": "^0.10.7",
    "@types/bull": "^3.15.9",
    "@types/bun": "^1.3.11",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/exceljs": "^0.5.3",
    "@types/express": "^5.0.5",
    "@types/express-form-data": "^2.0.5",
    "@types/express-session": "^1.18.2",
    "@types/fs-extra": "^11.0.4",
    "@types/handlebars": "^4.0.40",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.10",
    "@types/nodemailer": "^6.4.17",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/pdfkit": "^0.17.1",
    "@types/pg": "^8.20.0",
    "@types/puppeteer": "^5.4.7",
    "@types/redis": "^4.0.10",
    "@types/supertest": "^6.0.3",
    "@types/web-push": "^3.6.4",
    "@types/winston": "^2.4.4",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.6.0",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.1.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "author": "Pito Desri Pauzi",
  "license": "MIT",
  "description": "Ini adalah template untuk project express js + typescript + prisma orm"
}