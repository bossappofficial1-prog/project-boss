{
  "name": "boss-backend",
  "version": "1.0.0",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "ts-node-dev --ignore-watch node_modules --respawn --transpile-only -r dotenv/config --watch .env src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:seed": "ts-node --compiler-options \"{\\\"module\\\": \\\"commonjs\\\"}\" prisma/db/seed.ts",
    "db:seed:force": "ts-node --compiler-options \"{\\\"module\\\": \\\"commonjs\\\"}\" prisma/db/seed.ts --force",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset --force",
    "db:prepare": "npx prisma generate",
    "docs:install": "npm install --no-save redoc-cli@^0.13.21",
    "docs:generate": "redoc-cli build openapi.json --output docs/index.html --title 'BOSS API Documentation'",
    "docs:serve": "redoc-cli serve openapi.json --watch --port 8080",
    "socket:test": "node test-socket.js",
    "socket:test-public": "node test-socket-public.js",
    "elastic:test": "node test-elastic.js test",
    "elastic:setup": "node test-elastic.js setup",
    "elastic:search": "node test-elastic.js search",
    "test:type": "npx tsc --noEmit"
  },
  "prisma": {
    "seed": "npm run db:seed"
  },
  "keywords": [
    "service",
    "express",
    "backend",
    "docker"
  ],
  "dependencies": {
    "@elastic/elasticsearch": "^8.15.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@types/cors": "^2.8.19",
    "@types/express-session": "^1.18.2",
    "@types/passport": "^1.0.17",
    "@types/puppeteer": "^5.4.7",
    "amqplib": "^0.10.8",
    "axios": "^1.10.0",
    "bcryptjs": "^3.0.2",
    "bull": "^4.16.5",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.0.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "extract-zip": "^2.0.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "midtrans-client": "^1.4.3",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^7.0.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.17.1",
    "pg": "^8.11.1",
    "prisma": "^7.2.0",
    "puppeteer": "^24.36.0",
    "redis": "^5.9.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "twilio": "^5.7.3",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xendit-node": "^7.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.74"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/bull": "^3.15.9",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.5",
    "@types/express-form-data": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.10",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/pdfkit": "^0.17.1",
    "@types/pg": "^8.16.0",
    "@types/redis": "^4.0.10",
    "@types/supertest": "^6.0.3",
    "@types/winston": "^2.4.4",
    "jest": "^30.0.4",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "author": "Pito Desri Pauzi",
  "license": "MIT",
  "description": "Ini adalah template untuk project express js + typescript + prisma orm"
}
