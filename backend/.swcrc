{
    "$schema": "https://json.schemastore.org/swcrc",
    "jsc": {
        "target": "es2020",
        "parser": {
            "syntax": "typescript",
            "dynamicImport": true,
            "decorators": false
        },
        "keepClassNames": true
    },
    "module": {
        "type": "commonjs"
    },
    "sourceMaps": true,
    "minify": false
}