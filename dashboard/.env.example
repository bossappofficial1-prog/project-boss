# Backend API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:1234/api/v1

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_must_match_backend

# Application Environment
NEXT_PUBLIC_SOCKET_URL=http://localhost:1234
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3010
NEXT_PUBLIC_APP_NAME=BOSS Dashboard
NEXT_PUBLIC_APP_VERSION=1.0.0

# Midtrans Configuration (Optional)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your_midtrans_client_key_here

# Upload Configuration
NEXT_PUBLIC_MAX_FILE_SIZE=5242880
NEXT_PUBLIC_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Development Settings
NEXT_PUBLIC_DEBUG=true
