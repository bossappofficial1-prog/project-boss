# Frontend Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Base URL for API backend connection  
NUXT_PUBLIC_API_BASE_URL=http://localhost:6789/api/v1
NUXT_PUBLIC_BASE_URL=http://localhost:3000

# Midtrans Configuration (Payment Gateway)
# Get this from your Midtrans dashboard
# For sandbox: SB-Mid-client-xxxxxxxxx
# For production: Mid-client-xxxxxxxxx
NUXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-your-client-key-here

# Application Configuration
NUXT_PUBLIC_APP_NAME=BOSS
NUXT_PUBLIC_APP_VERSION=1.0.0

# Environment Mode (development, staging, production)
NODE_ENV=development

# Frontend Port (optional, defaults to 3000)
PORT=3000

# Base URL for frontend (used for callbacks, redirects, etc)
NUXT_PUBLIC_BASE_URL=http://localhost:3000
