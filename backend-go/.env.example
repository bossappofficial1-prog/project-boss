PORT=1235

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=project_boss

# Whitelist origin frontend untuk CORS
# Pisahkan banyak origin dengan koma
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional alias kalau mau pakai nama env lama
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Trusted proxy / reverse proxy IPs saja, bukan URL frontend
# Optional. Bisa kosong saat local development tanpa proxy.
CLIENT_IP=127.0.0.1 ::1
