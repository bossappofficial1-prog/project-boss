{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_API_URL": "https://api.bossapp.id/api/v1",
        "EXPO_PUBLIC_SOCKET_URL": "https://api.bossapp.id"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.bossapp.id/api/v1",
        "EXPO_PUBLIC_SOCKET_URL": "https://api.bossapp.id"
      }
    },
    "production-apk": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.bossapp.id/api/v1",
        "EXPO_PUBLIC_SOCKET_URL": "https://api.bossapp.id"
      }
    }
  }
}
